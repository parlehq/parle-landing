---
import type { UseCasePageData } from "../../data/developersUseCase";

interface Props {
  page: UseCasePageData;
}

const { page } = Astro.props as Props;
---

<main class="px-6 py-14 lg:px-8 lg:py-20">
  <div class="mx-auto flex w-full max-w-6xl flex-col gap-16 lg:gap-24">
    <section
      class="relative isolate overflow-hidden rounded-[2rem] border border-sand-600/14 bg-sand-100/45 px-6 py-8 shadow-[0_40px_120px_rgba(15,23,42,0.10)] sm:px-8 sm:py-10 lg:px-10 lg:py-12"
    >
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(37,99,235,0.08),transparent_32%),radial-gradient(circle_at_80%_24%,rgba(154,107,63,0.08),transparent_24%)]"
      >
      </div>
      <div
        class="pointer-events-none absolute inset-x-0 top-0 h-px bg-ink-300/20"
      >
      </div>
      <div
        class="relative grid gap-10 lg:grid-cols-[minmax(0,1.15fr)_minmax(20rem,0.85fr)] lg:items-start"
      >
        <div class="max-w-3xl">
          <p
            class="font-mono text-xs tracking-widest text-sand-600 uppercase sm:text-sm"
          >
            {page.hero.eyebrow}
          </p>
          <h1
            class="mt-5 max-w-4xl text-5xl font-semibold tracking-tight text-balance text-ink-100 sm:text-6xl lg:text-7xl"
          >
            {page.hero.title}
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-ink-200 sm:text-xl">
            {page.hero.intro}
          </p>
          <p
            class="mt-5 max-w-2xl text-base leading-7 text-ink-200 sm:text-lg sm:leading-8"
          >
            {page.hero.summary}
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            {
              page.hero.pills.map((pill) => (
                <span class="inline-flex items-center rounded-full border border-sand-600/16 bg-sand-100/65 px-4 py-2 font-mono text-xs tracking-widest text-ink-200 uppercase sm:text-sm">
                  {pill}
                </span>
              ))
            }
          </div>
        </div>

        <div
          class="relative overflow-hidden rounded-[1.75rem] border border-ink-100/12 bg-ink-950/78 p-5 sm:p-6"
        >
          <div
            class="pointer-events-none absolute inset-0 bg-[linear-gradient(135deg,rgba(37,99,235,0.06),transparent_60%)]"
          >
          </div>
          <div class="relative">
            <div
              class="flex items-center justify-between gap-4 border-b border-ink-100/10 pb-4"
            >
              <div>
                <p
                  class="font-mono text-xs tracking-widest text-sand-600 uppercase"
                >
                  Developer room surface
                </p>
                <p class="mt-2 text-lg font-semibold text-ink-100 sm:text-xl">
                  A workflow boundary that does not demand constant babysitting.
                </p>
              </div>
              <span
                class="rounded-full border border-emerald-300/25 bg-emerald-300/10 px-3 py-1 font-mono text-[0.68rem] tracking-widest text-emerald-700 uppercase"
              >
                live room
              </span>
            </div>

            <div class="mt-5 space-y-4">
              {
                page.hero.checkpoints.map((checkpoint) => (
                  <div class="rounded-2xl border border-sand-600/14 bg-sand-100/45 p-4">
                    <div class="flex items-start justify-between gap-4">
                      <div>
                        <p class="font-mono text-xs tracking-widest text-sand-600/84 uppercase">
                          {checkpoint.label}
                        </p>
                        <p class="mt-2 text-base font-semibold text-ink-100 sm:text-lg">
                          {checkpoint.value}
                        </p>
                      </div>
                      <span class="mt-1 inline-flex size-8 items-center justify-center rounded-full border border-sand-600/14 bg-sand-100/65 text-sm text-ink-200">
                        ↗
                      </span>
                    </div>
                    <p class="mt-3 text-sm leading-6 text-ink-200 sm:text-base">
                      {checkpoint.detail}
                    </p>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>

      <div class="relative mt-10 grid gap-4 md:grid-cols-3">
        {
          page.hero.outcomes.map((outcome) => (
            <div class="rounded-[1.5rem] border border-ink-100/10 bg-ink-950/48 p-5">
              <p class="text-lg font-semibold text-ink-100">{outcome.title}</p>
              <p class="mt-3 text-sm leading-6 text-ink-200 sm:text-base">
                {outcome.description}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    <section
      class="grid gap-8 lg:grid-cols-[minmax(0,0.7fr)_minmax(0,1.3fr)] lg:gap-10"
    >
      <div class="lg:sticky lg:top-24 lg:self-start">
        <p
          class="font-mono text-xs tracking-widest text-sand-600 uppercase sm:text-sm"
        >
          {page.workflow.eyebrow}
        </p>
        <h2
          class="mt-4 text-3xl font-semibold tracking-tight text-balance text-ink-100 sm:text-4xl lg:text-5xl"
        >
          {page.workflow.title}
        </h2>
        <p
          class="mt-5 max-w-xl text-base leading-7 text-ink-200 sm:text-lg sm:leading-8"
        >
          {page.workflow.description}
        </p>
      </div>

      <div class="grid gap-4">
        {
          page.workflow.steps.map((step) => (
            <article class="group relative overflow-hidden rounded-[1.75rem] border border-sand-600/14 bg-sand-100/45 p-5 transition duration-300 hover:border-ink-100/18 hover:bg-ink-100/6 sm:p-6">
              <div class="pointer-events-none absolute inset-y-0 left-0 w-1 rounded-full bg-linear-to-b from-sand-600 via-sand-500 to-cyan-300 opacity-70" />
              <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                <div class="flex items-center gap-4">
                  <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl border border-ink-100/12 bg-ink-950/82 font-mono text-sm text-ink-200">
                    {step.label}
                  </span>
                  <div>
                    <h3 class="text-xl font-semibold text-ink-100">
                      {step.title}
                    </h3>
                    <p class="mt-2 max-w-2xl text-sm leading-6 text-ink-200 sm:text-base sm:leading-7">
                      {step.description}
                    </p>
                  </div>
                </div>
                <p class="max-w-sm rounded-full border border-ink-100/10 bg-ink-950/62 px-4 py-2 text-xs leading-5 text-sand-600 sm:text-right sm:text-sm">
                  {step.note}
                </p>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section
      class="rounded-[2rem] border border-ink-100/10 bg-ink-950/36 px-6 py-8 sm:px-8 sm:py-10 lg:px-10"
    >
      <div class="max-w-3xl">
        <p
          class="font-mono text-xs tracking-widest text-sand-600 uppercase sm:text-sm"
        >
          {page.capabilities.eyebrow}
        </p>
        <h2
          class="mt-4 text-3xl font-semibold tracking-tight text-balance text-ink-100 sm:text-4xl lg:text-5xl"
        >
          {page.capabilities.title}
        </h2>
        <p
          class="mt-5 text-base leading-7 text-ink-200 sm:text-lg sm:leading-8"
        >
          {page.capabilities.description}
        </p>
      </div>

      <div class="mt-8 grid gap-4 lg:grid-cols-2 xl:grid-cols-3">
        {
          page.capabilities.items.map((item) => (
            <article class="rounded-[1.5rem] border border-sand-600/14 bg-sand-100/45 p-5 sm:p-6">
              <p class="font-mono text-xs tracking-widest text-sand-600 uppercase">
                {item.eyebrow}
              </p>
              <h3 class="mt-3 text-xl font-semibold text-ink-100">
                {item.title}
              </h3>
              <p class="mt-3 text-sm leading-6 text-ink-200 sm:text-base sm:leading-7">
                {item.description}
              </p>
              <p class="mt-5 rounded-2xl border border-ink-100/10 bg-ink-950/62 px-4 py-3 text-xs leading-5 text-sand-600 sm:text-sm">
                {item.evidence}
              </p>
            </article>
          ))
        }
      </div>
    </section>

    <section>
      <div class="max-w-3xl">
        <p
          class="font-mono text-xs tracking-widest text-sand-600 uppercase sm:text-sm"
        >
          {page.scenarios.eyebrow}
        </p>
        <h2
          class="mt-4 text-3xl font-semibold tracking-tight text-balance text-ink-100 sm:text-4xl lg:text-5xl"
        >
          {page.scenarios.title}
        </h2>
        <p
          class="mt-5 text-base leading-7 text-ink-200 sm:text-lg sm:leading-8"
        >
          {page.scenarios.description}
        </p>
      </div>

      <div class="mt-8 grid gap-4 xl:grid-cols-3">
        {
          page.scenarios.items.map((scenario) => (
            <article class="rounded-[1.75rem] border border-sand-600/14 bg-sand-100/45 p-5 sm:p-6">
              <h3 class="text-2xl font-semibold text-ink-100">
                {scenario.title}
              </h3>
              <p class="mt-3 text-sm leading-6 text-ink-200 sm:text-base sm:leading-7">
                {scenario.summary}
              </p>
              <ol class="mt-5 space-y-3 border-t border-ink-100/10 pt-5">
                {scenario.flow.map((line, index) => (
                  <li class="flex items-start gap-3 text-sm leading-6 text-ink-200 sm:text-base sm:leading-7">
                    <span class="mt-1 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-ink-100/10 bg-ink-950/74 font-mono text-xs text-ink-200">
                      {index + 1}
                    </span>
                    <span>{line}</span>
                  </li>
                ))}
              </ol>
              <p class="mt-5 rounded-[1.25rem] border border-cyan-300/20 bg-cyan-300/8 px-4 py-4 text-sm leading-6 text-cyan-800 sm:text-base sm:leading-7">
                {scenario.outcome}
              </p>
            </article>
          ))
        }
      </div>
    </section>

    <section
      class="grid gap-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(18rem,0.9fr)]"
    >
      <div
        class="rounded-[2rem] border border-sand-600/14 bg-sand-100/45 p-6 sm:p-8 lg:p-10"
      >
        <p
          class="font-mono text-xs tracking-widest text-sand-600 uppercase sm:text-sm"
        >
          {page.proof.eyebrow}
        </p>
        <h2
          class="mt-4 text-3xl font-semibold tracking-tight text-balance text-ink-100 sm:text-4xl"
        >
          {page.proof.title}
        </h2>
        <p
          class="mt-5 max-w-3xl text-base leading-7 text-ink-200 sm:text-lg sm:leading-8"
        >
          {page.proof.description}
        </p>
        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          {
            page.proof.items.map((item) => (
              <div class="rounded-[1.5rem] border border-ink-100/10 bg-ink-950/54 p-5">
                <p class="text-lg font-semibold text-ink-100">{item.title}</p>
                <p class="mt-3 text-sm leading-6 text-ink-200 sm:text-base sm:leading-7">
                  {item.detail}
                </p>
              </div>
            ))
          }
        </div>
        <p
          class="mt-6 rounded-[1.5rem] border border-amber-300/20 bg-amber-300/8 px-5 py-4 text-sm leading-6 text-amber-800 sm:text-base sm:leading-7"
        >
          {page.proof.disclaimer}
        </p>
      </div>

      <aside
        class="rounded-[2rem] border border-ink-100/10 bg-ink-950/70 p-6 sm:p-8"
      >
        <p
          class="font-mono text-xs tracking-widest text-sand-600 uppercase sm:text-sm"
        >
          Next step
        </p>
        <h2
          class="mt-4 text-3xl font-semibold tracking-tight text-balance text-ink-100 sm:text-4xl"
        >
          {page.cta.title}
        </h2>
        <p
          class="mt-5 text-base leading-7 text-ink-200 sm:text-lg sm:leading-8"
        >
          {page.cta.description}
        </p>

        <div class="mt-8 flex flex-col gap-3">
          <a
            class="inline-flex items-center justify-center rounded-full border border-ink-100/15 bg-ink-100 px-6 py-3 text-sm font-semibold text-ink-950 transition hover:-translate-y-px hover:bg-ink-100"
            href={page.cta.primaryHref}
          >
            {page.cta.primaryLabel}
          </a>
          {
            page.cta.secondaryLabel && page.cta.secondaryHref && (
              <a
                class="inline-flex items-center justify-center rounded-full border border-ink-100/15 px-6 py-3 text-sm font-semibold text-ink-100 transition hover:-translate-y-px hover:border-sand-600 hover:bg-ink-100/5"
                href={page.cta.secondaryHref}
                target="_blank"
                rel="noopener noreferrer"
              >
                {page.cta.secondaryLabel}
              </a>
            )
          }
        </div>
      </aside>
    </section>
  </div>
</main>
