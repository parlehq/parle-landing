---
import type {
  UseCaseAction,
  UseCasePageData,
} from "../../data/enterpriseUseCase";

interface Props {
  page: UseCasePageData;
}

const { page } = Astro.props;

const actionClasses = (variant: UseCaseAction["variant"] = "secondary") =>
  variant === "primary"
    ? "inline-flex items-center justify-center rounded-md border border-border-strong/40 bg-accent-ui px-5 py-3 text-sm font-semibold text-accent-fg transition hover:bg-accent-ui/80"
    : "inline-flex items-center justify-center rounded-md border border-border-strong/18 bg-surface/55 px-5 py-3 text-sm font-semibold text-fg transition hover:border-accent-ui/40 hover:bg-button-hover/8";
---

<div class="flex min-h-screen flex-col">
  <main class="flex-1 px-6 py-14 lg:px-8 lg:py-18">
    <div class="mx-auto w-full max-w-6xl space-y-18 lg:space-y-24">
      <section
        class="grid gap-10 lg:grid-cols-[minmax(0,1.05fr)_minmax(24rem,0.95fr)] lg:items-start lg:gap-12"
      >
        <div class="max-w-3xl">
          <p
            class="font-mono text-xs tracking-widest text-accent-ui uppercase sm:text-sm"
          >
            {page.eyebrow}
          </p>
          <h1
            class="mt-5 max-w-4xl text-5xl font-semibold tracking-tight text-balance text-fg sm:text-6xl lg:text-7xl"
          >
            {page.title}
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-muted sm:text-xl">
            {page.summary}
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            {
              page.audience.map((item) => (
                <span class="rounded-full border border-border-strong/14 bg-surface/45 px-3 py-1.5 text-sm text-muted">
                  {item}
                </span>
              ))
            }
          </div>

          <div class="mt-10 flex flex-wrap gap-4">
            {
              page.heroActions.map((action) => (
                <a href={action.href} class={actionClasses(action.variant)}>
                  {action.label}
                </a>
              ))
            }
          </div>

          <div class="mt-12 grid gap-4 sm:grid-cols-2">
            {
              page.heroSignals.map((signal) => (
                <div class="rounded-2xl border border-border-strong/14 bg-surface/45 p-4 backdrop-blur-sm">
                  <p class="text-sm leading-6 text-muted">{signal}</p>
                </div>
              ))
            }
          </div>
        </div>

        <aside
          class="relative overflow-hidden rounded-3xl border border-border/10 bg-[radial-gradient(circle_at_top,rgba(37,99,235,0.06),transparent_42%),var(--theme-surface-strong)] p-6 shadow-[0_30px_80px_rgba(15,23,42,0.10)] backdrop-blur sm:p-7 lg:sticky lg:top-22"
        >
          <div
            class="absolute inset-x-6 top-0 h-px bg-linear-to-r from-transparent via-accent-ui/45 to-transparent"
          >
          </div>
          <div class="flex items-center justify-between gap-4">
            <div>
              <p
                class="font-mono text-[0.7rem] tracking-widest text-accent-ui uppercase"
              >
                Governed workflow model
              </p>
              <h2 class="mt-3 text-2xl font-semibold text-fg">
                {page.scenario.title}
              </h2>
            </div>
            <span
              class="rounded-full border border-emerald-300/25 bg-emerald-300/12 px-3 py-1 text-xs font-semibold tracking-wide text-emerald-700 uppercase"
            >
              Room active
            </span>
          </div>

          <p class="mt-4 text-sm leading-6 text-muted sm:text-base">
            {page.scenario.summary}
          </p>

          <div class="mt-8 space-y-4">
            {
              page.scenario.steps.map((step) => (
                <div class="grid gap-4 rounded-2xl border border-border-strong/14 bg-surface/55 p-4 sm:grid-cols-[6.5rem_minmax(0,1fr)] sm:items-start">
                  <div>
                    <p class="font-mono text-[0.68rem] tracking-widest text-accent-ui uppercase">
                      {step.label}
                    </p>
                  </div>
                  <div>
                    <h3 class="text-base font-semibold text-fg sm:text-lg">
                      {step.title}
                    </h3>
                    <p class="mt-2 text-sm leading-6 text-muted">
                      {step.detail}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>

          <div
            class="mt-8 rounded-2xl border border-border-strong/18 bg-accent-subtle/10 p-5"
          >
            <p
              class="font-mono text-[0.68rem] tracking-widest text-accent-ui uppercase"
            >
              Why it matters
            </p>
            <div class="mt-4 space-y-3">
              {
                page.scenario.outcomes.map((outcome) => (
                  <div class="flex items-start gap-3 text-sm leading-6 text-muted">
                    <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-accent-subtle" />
                    <span>{outcome}</span>
                  </div>
                ))
              }
            </div>
          </div>
        </aside>
      </section>

      <section class="space-y-8">
        <div class="max-w-3xl">
          <p
            class="font-mono text-xs tracking-widest text-accent-ui uppercase sm:text-sm"
          >
            Pain points
          </p>
          <h2
            class="mt-4 text-3xl font-semibold tracking-tight text-fg sm:text-4xl"
          >
            {page.painSection.title}
          </h2>
          <p class="mt-4 text-lg leading-8 text-muted">
            {page.painSection.intro}
          </p>
        </div>
        <div class="grid gap-5 lg:grid-cols-3">
          {
            page.painSection.items.map((item) => (
              <article class="rounded-3xl border border-border-strong/14 bg-surface/45 p-6 backdrop-blur-sm">
                <p class="font-mono text-[0.7rem] tracking-widest text-accent-ui uppercase">
                  {item.eyebrow}
                </p>
                <h3 class="mt-4 text-2xl font-semibold text-fg">
                  {item.title}
                </h3>
                <p class="mt-4 text-base leading-7 text-muted">{item.body}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section
        class="rounded-[2rem] border border-border/10 bg-[linear-gradient(135deg,rgba(37,99,235,0.06),var(--theme-surface)_30%,var(--theme-surface-strong)_100%)] p-6 sm:p-8 lg:p-10"
      >
        <div class="max-w-3xl">
          <p
            class="font-mono text-xs tracking-widest text-accent-ui uppercase sm:text-sm"
          >
            Operating model
          </p>
          <h2
            class="mt-4 text-3xl font-semibold tracking-tight text-fg sm:text-4xl"
          >
            {page.outcomeSection.title}
          </h2>
          <p class="mt-4 text-lg leading-8 text-muted">
            {page.outcomeSection.intro}
          </p>
        </div>
        <div class="mt-8 grid gap-4 lg:grid-cols-2">
          {
            page.outcomeSection.items.map((item) => (
              <article class="rounded-3xl border border-border/10 bg-surface-inverse/56 p-6">
                <p class="font-mono text-[0.68rem] tracking-widest text-accent-ui uppercase">
                  {item.label}
                </p>
                <h3 class="mt-4 text-2xl font-semibold text-fg">
                  {item.title}
                </h3>
                <p class="mt-4 text-base leading-7 text-muted">{item.body}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="space-y-8">
        <div class="max-w-3xl">
          <p
            class="font-mono text-xs tracking-widest text-accent-ui uppercase sm:text-sm"
          >
            Comparison
          </p>
          <h2
            class="mt-4 text-3xl font-semibold tracking-tight text-fg sm:text-4xl"
          >
            {page.comparisonSection.title}
          </h2>
          <p class="mt-4 text-lg leading-8 text-muted">
            {page.comparisonSection.intro}
          </p>
        </div>

        <div
          class="overflow-hidden rounded-3xl border border-border-strong/14 bg-surface/45"
        >
          <div
            class="hidden grid-cols-[minmax(0,0.7fr)_minmax(0,1fr)_minmax(0,1fr)] border-b border-border-strong/14 bg-surface/55 px-6 py-4 text-sm font-semibold text-fg lg:grid"
          >
            <div>Concern</div>
            <div>Typical fallback</div>
            <div>Parlè room pattern</div>
          </div>
          <div class="divide-y divide-border/10">
            {
              page.comparisonSection.rows.map((row) => (
                <div class="grid gap-4 px-6 py-6 lg:grid-cols-[minmax(0,0.7fr)_minmax(0,1fr)_minmax(0,1fr)] lg:gap-6">
                  <div>
                    <p class="font-semibold text-fg">{row.concern}</p>
                  </div>
                  <div class="rounded-2xl border border-border/8 bg-surface-inverse/45 p-4 lg:border-0 lg:bg-transparent lg:p-0">
                    <p class="font-mono text-[0.68rem] tracking-widest text-rose-700 uppercase lg:hidden">
                      Typical fallback
                    </p>
                    <p class="mt-2 text-sm leading-6 text-muted lg:mt-0">
                      {row.defaultApproach}
                    </p>
                  </div>
                  <div class="rounded-2xl border border-border-strong/20 bg-accent-subtle/10 p-4 lg:border-0 lg:bg-transparent lg:p-0">
                    <p class="font-mono text-[0.68rem] tracking-widest text-accent-ui uppercase lg:hidden">
                      Parlè room pattern
                    </p>
                    <p class="mt-2 text-sm leading-6 text-muted lg:mt-0">
                      {row.governedRoom}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <section
        class="grid gap-8 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start lg:gap-10"
      >
        <div
          class="rounded-3xl border border-border-strong/14 bg-surface/45 p-6 sm:p-7 lg:sticky lg:top-22"
        >
          <p
            class="font-mono text-xs tracking-widest text-accent-ui uppercase sm:text-sm"
          >
            Proof and maturity
          </p>
          <h2
            class="mt-4 text-3xl font-semibold tracking-tight text-fg sm:text-4xl"
          >
            {page.proofSection.title}
          </h2>
          <p class="mt-4 text-lg leading-8 text-muted">
            {page.proofSection.intro}
          </p>
        </div>

        <div class="space-y-4">
          {
            page.proofSection.items.map((item) => (
              <article class="rounded-3xl border border-border-strong/14 bg-surface/45 p-6">
                <h3 class="text-xl font-semibold text-fg sm:text-2xl">
                  {item.title}
                </h3>
                <p class="mt-3 text-base leading-7 text-muted">{item.body}</p>
                {item.note && (
                  <p class="mt-4 font-mono text-[0.68rem] tracking-widest text-accent-ui uppercase">
                    {item.note}
                  </p>
                )}
              </article>
            ))
          }
        </div>
      </section>

      <section class="space-y-8">
        <div class="max-w-3xl">
          <p
            class="font-mono text-xs tracking-widest text-accent-ui uppercase sm:text-sm"
          >
            First applications
          </p>
          <h2
            class="mt-4 text-3xl font-semibold tracking-tight text-fg sm:text-4xl"
          >
            {page.scenarioSection.title}
          </h2>
          <p class="mt-4 text-lg leading-8 text-muted">
            {page.scenarioSection.intro}
          </p>
        </div>

        <div class="grid gap-5 lg:grid-cols-2">
          {
            page.scenarioSection.items.map((item) => (
              <article class="flex h-full flex-col rounded-3xl border border-border-strong/14 bg-surface/45 p-6">
                <h3 class="text-2xl font-semibold text-fg">{item.title}</h3>
                <p class="mt-4 flex-1 text-base leading-7 text-muted">
                  {item.body}
                </p>
                <div class="mt-6 rounded-2xl border border-border-strong/18 bg-accent-subtle/10 p-4">
                  <p class="font-mono text-[0.68rem] tracking-widest text-accent-ui uppercase">
                    Enterprise outcome
                  </p>
                  <p class="mt-2 text-sm leading-6 text-muted">
                    {item.outcome}
                  </p>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section
        class="rounded-[2rem] border border-border/10 bg-[radial-gradient(circle_at_top_left,rgba(37,99,235,0.08),transparent_34%),var(--theme-surface-strong)] p-7 sm:p-9 lg:p-10"
      >
        <div class="max-w-3xl">
          <p
            class="font-mono text-xs tracking-widest text-accent-ui uppercase sm:text-sm"
          >
            Closing frame
          </p>
          <h2
            class="mt-4 text-3xl font-semibold tracking-tight text-fg sm:text-4xl"
          >
            {page.closingSection.title}
          </h2>
          <p class="mt-4 text-lg leading-8 text-muted">
            {page.closingSection.body}
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            {
              page.closingSection.actions.map((action) => (
                <a href={action.href} class={actionClasses(action.variant)}>
                  {action.label}
                </a>
              ))
            }
          </div>
        </div>
      </section>
    </div>
  </main>
</div>
