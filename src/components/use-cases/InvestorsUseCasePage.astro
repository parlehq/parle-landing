---
import Layout from "../../layouts/Layout.astro";
import SiteHeader from "../SiteHeader.astro";
import SiteFooter from "../SiteFooter.astro";
import type { UseCasePageData } from "../../data/investorsUseCase";

interface Props {
  page: UseCasePageData;
  path?: string;
}

const { page, path = "/" } = Astro.props;
const workflowCount = page.workflow.length;
---

<Layout title={page.seoTitle} description={page.seoDescription}>
  <div class="flex min-h-screen flex-col">
    <SiteHeader path={path} />

    <main class="flex-1 px-6 py-14 lg:px-8 lg:py-20">
      <div class="mx-auto flex w-full max-w-7xl flex-col gap-16 lg:gap-24">
        <section
          class="grid gap-10 lg:grid-cols-[minmax(0,1.1fr)_minmax(18rem,0.9fr)] lg:items-start lg:gap-12"
        >
          <div class="max-w-3xl">
            <p class="font-mono text-sm tracking-widest text-ink-300 uppercase">
              {page.eyebrow}
            </p>
            <h1
              class="mt-6 text-5xl font-semibold tracking-tight text-balance text-white sm:text-6xl lg:text-7xl"
            >
              {page.title}
            </h1>
            <p
              class="mt-6 max-w-2xl text-lg leading-8 text-ink-100/78 sm:text-xl"
            >
              {page.description}
            </p>

            <div class="mt-8 flex flex-wrap gap-3">
              {
                page.audiences.map((audience) => (
                  <span class="rounded-full border border-white/12 bg-white/5 px-4 py-2 text-sm font-medium text-ink-100/88">
                    {audience.title}
                  </span>
                ))
              }
            </div>

            <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center">
              <a
                href={page.primaryCta.href}
                target={page.primaryCta.external ? "_blank" : undefined}
                rel={page.primaryCta.external
                  ? "noopener noreferrer"
                  : undefined}
                class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-ink-950 transition hover:bg-ink-100"
              >
                {page.primaryCta.label}
              </a>
              <a
                href={page.secondaryCta.href}
                target={page.secondaryCta.external ? "_blank" : undefined}
                rel={page.secondaryCta.external
                  ? "noopener noreferrer"
                  : undefined}
                class="inline-flex items-center justify-center rounded-full border border-white/14 bg-white/4 px-6 py-3 text-sm font-semibold text-white transition hover:border-ink-400 hover:bg-white/8"
              >
                {page.secondaryCta.label}
              </a>
            </div>
          </div>

          <div class="relative lg:pt-5">
            <div
              class="absolute inset-x-5 top-8 h-48 rounded-full bg-ink-500/16 blur-3xl"
            >
            </div>
            <div
              class="relative overflow-hidden rounded-3xl border border-white/12 bg-ink-950/70 p-6 shadow-2xl shadow-black/20 backdrop-blur sm:p-7"
            >
              <div class="flex items-center justify-between gap-4">
                <div>
                  <p
                    class="font-mono text-xs tracking-widest text-ink-300 uppercase"
                  >
                    {page.heroBoardTitle}
                  </p>
                  <p class="mt-3 max-w-sm text-sm leading-6 text-ink-100/70">
                    {page.heroBoardSummary}
                  </p>
                </div>
                <span
                  class="rounded-full border border-ink-400/30 bg-ink-400/10 px-3 py-1 font-mono text-xs tracking-widest text-ink-200 uppercase"
                >
                  Live process
                </span>
              </div>

              <div class="mt-8 space-y-4">
                {
                  page.heroBoardItems.map((item, index) => (
                    <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                      <div class="flex items-start gap-4">
                        <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-ink-400/25 bg-ink-400/10 font-mono text-xs text-ink-200">
                          0{index + 1}
                        </div>
                        <div>
                          <p class="text-sm font-semibold text-white">
                            {item.label}
                          </p>
                          <p class="mt-2 text-sm leading-6 text-ink-100/68">
                            {item.detail}
                          </p>
                        </div>
                      </div>
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
        </section>

        <section
          class="grid gap-6 lg:grid-cols-[minmax(16rem,0.7fr)_minmax(0,1.3fr)] lg:gap-8"
        >
          <div class="rounded-3xl border border-white/10 bg-white/4 p-6 lg:p-7">
            <p class="font-mono text-xs tracking-widest text-ink-300 uppercase">
              Who it serves
            </p>
            <h2 class="mt-4 text-2xl font-semibold text-white sm:text-3xl">
              {page.audienceIntro}
            </h2>
          </div>

          <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
            {
              page.audiences.map((audience) => (
                <article class="rounded-3xl border border-white/10 bg-white/4 p-5">
                  <h3 class="text-base font-semibold text-white">
                    {audience.title}
                  </h3>
                  <p class="mt-3 text-sm leading-6 text-ink-100/68">
                    {audience.detail}
                  </p>
                </article>
              ))
            }
          </div>
        </section>

        <section
          class="grid gap-8 lg:grid-cols-[minmax(16rem,0.62fr)_minmax(0,1.38fr)] lg:gap-10"
        >
          <div class="lg:sticky lg:top-24 lg:self-start">
            <p class="font-mono text-xs tracking-widest text-ink-300 uppercase">
              {page.workflowEyebrow}
            </p>
            <h2 class="mt-4 text-3xl font-semibold text-white sm:text-4xl">
              {page.workflowTitle}
            </h2>
            <p
              class="mt-4 max-w-md text-base leading-7 text-ink-100/72 sm:text-lg sm:leading-8"
            >
              {page.workflowDescription}
            </p>
          </div>

          <div class="space-y-4">
            {
              page.workflow.map((step, index) => (
                <article class="relative overflow-hidden rounded-3xl border border-white/10 bg-white/4 p-6 sm:p-7">
                  <div class="grid gap-5 lg:grid-cols-[auto_minmax(0,1fr)] lg:items-start lg:gap-6">
                    <div class="flex items-center gap-4 lg:flex-col lg:items-start lg:gap-3">
                      <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl border border-ink-400/25 bg-ink-400/10 font-mono text-sm text-ink-100">
                        {step.phase}
                      </span>
                      <div class="h-px flex-1 bg-linear-to-r from-ink-400/40 to-transparent lg:h-20 lg:w-px lg:bg-linear-to-b" />
                    </div>
                    <div>
                      <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between sm:gap-6">
                        <h3 class="max-w-xl text-xl font-semibold text-white sm:text-2xl">
                          {step.title}
                        </h3>
                        <span class="rounded-full border border-white/10 bg-ink-950/60 px-3 py-1.5 font-mono text-xs tracking-widest text-ink-200 uppercase">
                          Step {index + 1} of {workflowCount}
                        </span>
                      </div>
                      <p class="mt-4 max-w-3xl text-base leading-7 text-ink-100/74 sm:text-lg sm:leading-8">
                        {step.detail}
                      </p>
                      <div class="mt-5 rounded-2xl border border-ink-400/18 bg-ink-900/45 p-4">
                        <p class="font-mono text-xs tracking-widest text-ink-300 uppercase">
                          Why it matters
                        </p>
                        <p class="mt-2 text-sm leading-6 text-ink-100/72">
                          {step.signal}
                        </p>
                      </div>
                    </div>
                  </div>
                </article>
              ))
            }
          </div>
        </section>

        <section>
          <p class="font-mono text-xs tracking-widest text-ink-300 uppercase">
            {page.scenarioEyebrow}
          </p>
          <div
            class="mt-4 grid gap-6 xl:grid-cols-[minmax(0,0.82fr)_minmax(0,1.18fr)] xl:items-end"
          >
            <div>
              <h2 class="text-3xl font-semibold text-white sm:text-4xl">
                {page.scenarioTitle}
              </h2>
            </div>
            <p
              class="max-w-3xl text-base leading-7 text-ink-100/72 sm:text-lg sm:leading-8"
            >
              {page.scenarioDescription}
            </p>
          </div>

          <div class="mt-8 grid gap-5 xl:grid-cols-3">
            {
              page.scenarios.map((scenario) => (
                <article class="flex h-full flex-col rounded-3xl border border-white/10 bg-white/4 p-6 sm:p-7">
                  <p class="font-mono text-xs tracking-widest text-ink-300 uppercase">
                    {scenario.eyebrow}
                  </p>
                  <h3 class="mt-4 text-2xl font-semibold text-white">
                    {scenario.title}
                  </h3>
                  <p class="mt-4 text-base leading-7 text-ink-100/72">
                    {scenario.detail}
                  </p>
                  <ul class="mt-6 space-y-3 text-sm leading-6 text-ink-100/72">
                    {scenario.outcomes.map((outcome) => (
                      <li class="flex gap-3">
                        <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-ink-300" />
                        <span>{outcome}</span>
                      </li>
                    ))}
                  </ul>
                </article>
              ))
            }
          </div>
        </section>

        <section
          class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.9fr)] lg:gap-8"
        >
          <div
            class="rounded-4xl border border-white/10 bg-white/4 p-6 sm:p-7 lg:p-8"
          >
            <p class="font-mono text-xs tracking-widest text-ink-300 uppercase">
              {page.principlesEyebrow}
            </p>
            <h2
              class="mt-4 max-w-2xl text-3xl font-semibold text-white sm:text-4xl"
            >
              {page.principlesTitle}
            </h2>
            <div class="mt-8 grid gap-4">
              {
                page.principles.map((principle) => (
                  <article class="rounded-3xl border border-white/10 bg-ink-950/45 p-5">
                    <h3 class="text-lg font-semibold text-white">
                      {principle.title}
                    </h3>
                    <p class="mt-3 text-sm leading-6 text-ink-100/70 sm:text-base sm:leading-7">
                      {principle.detail}
                    </p>
                  </article>
                ))
              }
            </div>
          </div>

          <div
            class="rounded-4xl border border-white/10 bg-ink-950/65 p-6 sm:p-7 lg:p-8"
          >
            <p class="font-mono text-xs tracking-widest text-ink-300 uppercase">
              {page.proofTitle}
            </p>
            <p
              class="mt-4 text-base leading-7 text-ink-100/72 sm:text-lg sm:leading-8"
            >
              {page.proofDescription}
            </p>
            <div class="mt-8 space-y-4">
              {
                page.proofPoints.map((point) => (
                  <article class="rounded-3xl border border-ink-400/16 bg-white/4 p-5">
                    <h3 class="text-base font-semibold text-white">
                      {point.title}
                    </h3>
                    <p class="mt-3 text-sm leading-6 text-ink-100/70 sm:text-base sm:leading-7">
                      {point.detail}
                    </p>
                  </article>
                ))
              }
            </div>
          </div>
        </section>

        <section
          class="overflow-hidden rounded-4xl border border-white/10 bg-linear-to-br from-ink-900/75 via-ink-950/80 to-ink-900/60 p-8 sm:p-10 lg:p-12"
        >
          <div
            class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end"
          >
            <div class="max-w-3xl">
              <p
                class="font-mono text-xs tracking-widest text-ink-300 uppercase"
              >
                Next step
              </p>
              <h2 class="mt-4 text-3xl font-semibold text-white sm:text-4xl">
                {page.closingTitle}
              </h2>
              <p
                class="mt-4 text-base leading-7 text-ink-100/72 sm:text-lg sm:leading-8"
              >
                {page.closingDescription}
              </p>
            </div>
            <div
              class="flex flex-col gap-3 sm:flex-row lg:flex-col xl:flex-row"
            >
              <a
                href={page.primaryCta.href}
                target={page.primaryCta.external ? "_blank" : undefined}
                rel={page.primaryCta.external
                  ? "noopener noreferrer"
                  : undefined}
                class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-ink-950 transition hover:bg-ink-100"
              >
                {page.primaryCta.label}
              </a>
              <a
                href={page.secondaryCta.href}
                target={page.secondaryCta.external ? "_blank" : undefined}
                rel={page.secondaryCta.external
                  ? "noopener noreferrer"
                  : undefined}
                class="inline-flex items-center justify-center rounded-full border border-white/14 bg-white/4 px-6 py-3 text-sm font-semibold text-white transition hover:border-ink-400 hover:bg-white/8"
              >
                {page.secondaryCta.label}
              </a>
            </div>
          </div>
        </section>
      </div>
    </main>

    <SiteFooter />
  </div>
</Layout>
