---
import Layout from "../../layouts/Layout.astro";
import SiteHeader from "../SiteHeader.astro";
import SiteFooter from "../SiteFooter.astro";
import type { UseCasePageData } from "../../data/investorsUseCase";

interface Props {
  page: UseCasePageData;
  path?: string;
}

const { page, path = "/" } = Astro.props;
const audienceCount = page.audiences.length;
---

<Layout title={page.seoTitle} description={page.seoDescription}>
  <div class="flex min-h-screen flex-col">
    <SiteHeader path={path} />

    <main class="flex-1 px-6 py-14 lg:px-8 lg:py-20">
      <div class="mx-auto flex w-full max-w-7xl flex-col gap-16 lg:gap-24">
        <section
          class="mx-auto flex max-w-3xl flex-col items-center py-10 text-center sm:py-16 lg:py-20"
        >
          <p class="font-mono text-sm tracking-widest text-ink-300 uppercase">
            {page.eyebrow}
          </p>
          <h1
            class="mt-6 text-5xl font-semibold tracking-tight text-balance text-ink-100 sm:text-6xl lg:text-7xl"
          >
            {page.title}
          </h1>
          <p
            class="mt-6 max-w-2xl text-lg leading-8 text-balance text-ink-200 sm:text-xl"
          >
            {page.description}
          </p>

          <div
            class="mt-10 flex flex-col items-center gap-5 sm:flex-row sm:gap-6"
          >
            <a
              href={page.primaryCta.href}
              target={page.primaryCta.external ? "_blank" : undefined}
              rel={page.primaryCta.external ? "noopener noreferrer" : undefined}
              class="inline-flex items-center justify-center gap-2 rounded-md bg-ink-100 px-6 py-3 text-sm font-semibold text-ink-950 transition hover:bg-ink-100"
            >
              {page.primaryCta.label}
              <span aria-hidden="true">→</span>
            </a>
            <a
              href={page.secondaryCta.href}
              target={page.secondaryCta.external ? "_blank" : undefined}
              rel={page.secondaryCta.external
                ? "noopener noreferrer"
                : undefined}
              class="group inline-flex items-center gap-2 text-sm font-semibold text-ink-200 transition hover:text-ink-100"
            >
              {page.secondaryCta.label}
              <span
                class="transition group-hover:translate-x-0.5"
                aria-hidden="true">→</span
              >
            </a>
          </div>
        </section>

        <aside
          class="relative mx-auto w-full max-w-2xl overflow-hidden rounded-md border border-ink-100/10 bg-[radial-gradient(circle_at_top,rgba(37,99,235,0.06),transparent_42%),rgba(255,255,255,0.78)] p-6 shadow-[0_30px_80px_rgba(15,23,42,0.10)] backdrop-blur sm:p-7"
        >
          <div
            class="absolute inset-x-6 top-0 h-px bg-linear-to-r from-transparent via-ink-300/60 to-transparent"
          >
          </div>
          <div class="flex items-center justify-between gap-4">
            <div>
              <p
                class="font-mono text-xs tracking-widest text-ink-300 uppercase"
              >
                {page.heroBoardTitle}
              </p>
              <p class="mt-3 max-w-sm text-sm leading-6 text-ink-200">
                {page.heroBoardSummary}
              </p>
            </div>
          </div>

          <div class="mt-8 space-y-4">
            {
              page.heroBoardItems.map((item, index) => (
                <div class="rounded-md border border-ink-100/10 bg-sand-100/55 p-4">
                  <div class="flex items-start gap-4">
                    <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-ink-400/25 bg-ink-400/10 font-mono text-xs text-ink-200">
                      0{index + 1}
                    </div>
                    <div>
                      <p class="text-sm font-semibold text-ink-100">
                        {item.label}
                      </p>
                      <p class="mt-2 text-sm leading-6 text-ink-200">
                        {item.detail}
                      </p>
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </aside>

        <section
          class="grid gap-8 lg:grid-cols-[minmax(16rem,0.62fr)_minmax(0,1.38fr)] lg:gap-10"
        >
          <div class="lg:sticky lg:top-24 lg:self-start">
            <p class="font-mono text-xs tracking-widest text-ink-300 uppercase">
              Who it serves
            </p>
            <h2 class="mt-4 text-3xl font-semibold text-ink-100 sm:text-4xl">
              {page.audienceIntro}
            </h2>
          </div>

          <div class="space-y-4">
            {
              page.audiences.map((audience, index) => (
                <article class="relative overflow-hidden rounded-md border border-ink-100/10 bg-sand-100/45 p-6 sm:p-7">
                  <div class="grid gap-5 lg:grid-cols-[auto_minmax(0,1fr)] lg:items-start lg:gap-6">
                    <div class="flex items-center gap-4 lg:flex-col lg:items-start lg:gap-3">
                      <span class="inline-flex h-12 w-12 items-center justify-center rounded-md border border-ink-400/25 bg-ink-400/10 font-mono text-sm text-ink-100">
                        0{index + 1}
                      </span>
                      <div class="h-px flex-1 bg-linear-to-r from-ink-400/40 to-transparent lg:h-20 lg:w-px lg:bg-linear-to-b" />
                    </div>
                    <div>
                      <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between sm:gap-6">
                        <h3 class="max-w-xl text-xl font-semibold text-ink-100 sm:text-2xl">
                          {audience.title}
                        </h3>
                        <span class="rounded-full border border-ink-100/10 bg-ink-950/60 px-3 py-1.5 font-mono text-xs tracking-widest text-ink-200 uppercase">
                          {index + 1} of {audienceCount}
                        </span>
                      </div>
                      <p class="mt-4 max-w-3xl text-base leading-7 text-ink-200 sm:text-lg sm:leading-8">
                        {audience.detail}
                      </p>
                    </div>
                  </div>
                </article>
              ))
            }
          </div>
        </section>

        <section>
          <p class="font-mono text-xs tracking-widest text-ink-300 uppercase">
            {page.scenarioEyebrow}
          </p>
          <div
            class="mt-4 grid gap-6 xl:grid-cols-[minmax(0,0.82fr)_minmax(0,1.18fr)] xl:items-end"
          >
            <div>
              <h2 class="text-3xl font-semibold text-ink-100 sm:text-4xl">
                {page.scenarioTitle}
              </h2>
            </div>
            <p
              class="max-w-3xl text-base leading-7 text-ink-200 sm:text-lg sm:leading-8"
            >
              {page.scenarioDescription}
            </p>
          </div>

          <div class="mt-8 grid gap-5 xl:grid-cols-3">
            {
              page.scenarios.map((scenario) => (
                <article class="flex h-full flex-col rounded-md border border-ink-100/10 bg-sand-100/45 p-6 sm:p-7">
                  <p class="font-mono text-xs tracking-widest text-ink-300 uppercase">
                    {scenario.eyebrow}
                  </p>
                  <h3 class="mt-4 text-2xl font-semibold text-ink-100">
                    {scenario.title}
                  </h3>
                  <p class="mt-4 text-base leading-7 text-ink-200">
                    {scenario.detail}
                  </p>
                  <ul class="mt-6 space-y-3 text-sm leading-6 text-ink-200">
                    {scenario.outcomes.map((outcome) => (
                      <li class="flex gap-3">
                        <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-ink-300" />
                        <span>{outcome}</span>
                      </li>
                    ))}
                  </ul>
                </article>
              ))
            }
          </div>
        </section>

        <section
          class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.9fr)] lg:gap-8"
        >
          <div
            class="rounded-md border border-ink-100/10 bg-sand-100/45 p-6 sm:p-7 lg:p-8"
          >
            <p class="font-mono text-xs tracking-widest text-ink-300 uppercase">
              {page.principlesEyebrow}
            </p>
            <h2
              class="mt-4 max-w-2xl text-3xl font-semibold text-ink-100 sm:text-4xl"
            >
              {page.principlesTitle}
            </h2>
            <div class="mt-8 grid gap-4">
              {
                page.principles.map((principle) => (
                  <article class="rounded-md border border-ink-100/10 bg-ink-950/45 p-5">
                    <h3 class="text-lg font-semibold text-ink-100">
                      {principle.title}
                    </h3>
                    <p class="mt-3 text-sm leading-6 text-ink-200 sm:text-base sm:leading-7">
                      {principle.detail}
                    </p>
                  </article>
                ))
              }
            </div>
          </div>

          <div
            class="rounded-md border border-ink-100/10 bg-ink-950/65 p-6 sm:p-7 lg:p-8"
          >
            <p class="font-mono text-xs tracking-widest text-ink-300 uppercase">
              {page.proofTitle}
            </p>
            <p
              class="mt-4 text-base leading-7 text-ink-200 sm:text-lg sm:leading-8"
            >
              {page.proofDescription}
            </p>
            <div class="mt-8 space-y-4">
              {
                page.proofPoints.map((point) => (
                  <article class="rounded-md border border-ink-400/16 bg-sand-100/45 p-5">
                    <h3 class="text-base font-semibold text-ink-100">
                      {point.title}
                    </h3>
                    <p class="mt-3 text-sm leading-6 text-ink-200 sm:text-base sm:leading-7">
                      {point.detail}
                    </p>
                  </article>
                ))
              }
            </div>
          </div>
        </section>

        <section
          class="overflow-hidden rounded-md border border-ink-100/10 bg-linear-to-br from-ink-900/75 via-ink-950/80 to-ink-900/60 p-8 sm:p-10 lg:p-12"
        >
          <div
            class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end"
          >
            <div class="max-w-3xl">
              <p
                class="font-mono text-xs tracking-widest text-ink-300 uppercase"
              >
                Next step
              </p>
              <h2 class="mt-4 text-3xl font-semibold text-ink-100 sm:text-4xl">
                {page.closingTitle}
              </h2>
              <p
                class="mt-4 text-base leading-7 text-ink-200 sm:text-lg sm:leading-8"
              >
                {page.closingDescription}
              </p>
            </div>
            <div
              class="flex flex-col gap-3 sm:flex-row lg:flex-col xl:flex-row"
            >
              <a
                href={page.primaryCta.href}
                target={page.primaryCta.external ? "_blank" : undefined}
                rel={page.primaryCta.external
                  ? "noopener noreferrer"
                  : undefined}
                class="inline-flex items-center justify-center rounded-md bg-ink-100 px-6 py-3 text-sm font-semibold text-ink-950 transition hover:bg-ink-100"
              >
                {page.primaryCta.label}
              </a>
              <a
                href={page.secondaryCta.href}
                target={page.secondaryCta.external ? "_blank" : undefined}
                rel={page.secondaryCta.external
                  ? "noopener noreferrer"
                  : undefined}
                class="inline-flex items-center justify-center rounded-md border border-ink-100/14 bg-sand-100/45 px-6 py-3 text-sm font-semibold text-ink-100 transition hover:border-ink-400 hover:bg-ink-100/8"
              >
                {page.secondaryCta.label}
              </a>
            </div>
          </div>
        </section>
      </div>
    </main>

    <SiteFooter />
  </div>
</Layout>
