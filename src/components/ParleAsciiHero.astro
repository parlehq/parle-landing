    "                 room open                   ",
  ],
];

const frameWidth = Math.max(
  ...rawFrames.flatMap((frame) => frame.map((row) => row.trim().length)),
);
const frames = rawFrames.map((frame) =>
  frame.map((row) => {
    const trimmed = row.trim();
    const left = Math.floor((frameWidth - trimmed.length) / 2);
    return `${" ".repeat(left)}${trimmed}`.padEnd(frameWidth, " ");
  }),
);

function toneFor(char: string) {
  if (
    char === "P" ||
    char === "A" ||
    char === "R" ||
    char === "L" ||
    char === "E"
  ) {
    return "bright";
  }
  if (char === "@" || char === "$") {
    return "body";
  }
  if (char === "o") {
    return "ink";
  }
  if (char === "x" || char === "+" || char === "=") {
    return "halo";
  }
  return "muted";
}
---

<section
  class="ascii-shell"
  aria-label="Parlè bounded agent exchange animation"
>
  <div class="terminal-bar">
    <div class="window-dots" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>
    <p>parle://room/diligence</p>
  </div>

  <pre
    class="screen"
    aria-label="Animated ASCII diagram"
    data-ascii-hero>
{frames[0].map((row) => (
  <span class="ascii-row">{Array.from(row).map((char) => (
    <span class:list={["ascii-cell", toneFor(char)]}>{char}</span>
  ))}</span>
))}</pre>
  <script
    type="application/json"
    id="parle-ascii-frames"
    set:html={JSON.stringify(frames)}
  />
</section>

<script>
  const hero = document.querySelector("[data-ascii-hero]");
  const frameSource = document.getElementById("parle-ascii-frames");
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  function toneFor(char) {
    if (["P", "A", "R", "L", "E"].includes(char)) return "bright";
    if (char === "@" || char === "$") return "body";
    if (char === "o") return "ink";
    if (char === "x" || char === "+" || char === "=") return "halo";
    return "muted";
  }

  if (hero && frameSource && !reducedMotion.matches) {
    const frames = JSON.parse(frameSource.textContent || "[]");
    const cells = Array.from(hero.querySelectorAll(".ascii-cell"));
    let frameIndex = 0;

    window.setInterval(() => {
      frameIndex = (frameIndex + 1) % frames.length;
      const chars = frames[frameIndex].join("");

      cells.forEach((cell, index) => {
        const char = chars[index] || " ";
        cell.textContent = char;
        cell.className = `ascii-cell ${toneFor(char)}`;
      });
    }, 210);
  }
</script>

<style>
  .ascii-shell {
    overflow: hidden;
    border: 1px solid rgba(147, 197, 253, 0.2);
    border-radius: 1.35rem;
    background: rgba(5, 9, 19, 0.86);
    box-shadow:
      0 24px 70px rgba(2, 6, 23, 0.42),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid rgba(147, 197, 253, 0.14);
    background: rgba(15, 23, 42, 0.72);
    padding: 0.8rem 1rem;
    color: rgba(219, 234, 254, 0.62);
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .window-dots {
    display: flex;
    gap: 0.45rem;
  }

  .window-dots span {
    height: 0.58rem;
    width: 0.58rem;
    border-radius: 999px;
    background: rgba(147, 197, 253, 0.28);
  }

  .window-dots span:nth-child(2) {
    background: rgba(96, 165, 250, 0.4);
  }

  .window-dots span:nth-child(3) {
    background: rgba(239, 246, 255, 0.44);
  }

  .screen {
    display: grid;
    place-items: center;
    min-height: clamp(19rem, 34vw, 25rem);
    margin: 0;
    overflow: hidden;
    padding: clamp(1rem, 2.8vw, 2.4rem);
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: clamp(0.54rem, 1vw, 0.82rem);
    line-height: 1.08;
    white-space: pre;
  }

  .ascii-row {
    display: block;
    height: 1.08em;
  }

  .ascii-cell {
    display: inline-block;
    min-width: 1ch;
    transition:
      color 160ms ease,
      text-shadow 160ms ease,
      opacity 160ms ease;
  }

  .halo {
    color: rgba(96, 165, 250, 0.9);
    text-shadow: 0 0 16px rgba(37, 99, 235, 0.42);
  }

  .body {
    color: rgba(239, 246, 255, 0.86);
    text-shadow: 0 0 18px rgba(219, 234, 254, 0.12);
  }

  .ink {
    color: rgba(219, 234, 254, 0.66);
  }

  .bright {
    color: #ffffff;
    text-shadow: 0 0 24px rgba(147, 197, 253, 0.5);
  }

  .muted {
    color: rgba(147, 197, 253, 0.54);
  }

  @media (max-width: 700px) {
    .screen {
      min-height: 17rem;
      font-size: clamp(0.42rem, 1.45vw, 0.62rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ascii-cell {
      transition: none;
    }
  }
</style>
