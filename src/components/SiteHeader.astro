---
const { path } = Astro.props;
---

<header
  class="sticky top-0 z-20 border-b border-white/10 bg-ink-950/70 backdrop-blur"
>
  <div
    class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 lg:px-8"
  >
    <a
      href="/"
      class="text-lg font-semibold tracking-[0.24em] uppercase text-ink-100"
      >Parlè</a
    >
    <nav class="flex items-center gap-6 text-sm text-ink-300">
      <a
        href="/about"
        class:list={[
          "transition hover:text-white",
          path === "/about/" ? "text-white" : "",
        ]}
      >
        About
      </a>
      <a
        href="https://parle.sh"
        target="_blank"
        rel="noopener"
        class="rounded-full border border-white/15 px-4 py-2 font-medium text-white transition hover:border-ink-400 hover:bg-white/5"
      >
        Parle.sh
      </a>
    </nav>
  </div>
</header>
