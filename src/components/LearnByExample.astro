---
type ExampleStep = {
  label: string;
  text: string;
  // Bare Tailwind color name (e.g. "cyan", "emerald"). Safelisted in global.css.
  color?: string;
};

type ArtifactRow = {
  label: string;
  value: string;
  emphasized?: boolean;
};

interface Props {
  eyebrow: string;
  title: string;
  prompt: string;
  outcome: string;
  description?: string;
  steps: ExampleStep[];
  feature: string;
  featureLabel: string;
  cta?: string;
  mirrored?: boolean;
  artifactTitle?: string;
  artifactStatus?: string;
  artifactRows?: ArtifactRow[];
}

const {
  eyebrow,
  title,
  prompt,
  outcome,
  description,
  steps,
  feature,
  featureLabel,
  cta = "Learn the pattern",
  mirrored = false,
  artifactTitle = "Approved artifact",
  artifactStatus = "sealed",
  artifactRows,
} = Astro.props;

const DEFAULT_COLOR = "violet";

const timeline = [
  { label: "Input", text: prompt, color: "orange", delay: 0 },
  ...steps.map((step, index) => ({
    ...step,
    color: step.color ?? DEFAULT_COLOR,
    delay: (index + 1) * 140,
  })),
  {
    label: "Output",
    text: outcome,
    color: "emerald",
    delay: (steps.length + 1) * 140,
  },
];

const resolvedArtifactRows = artifactRows ?? [
  { label: "room", value: "agent-exchange" },
  { label: "feature", value: feature },
  { label: "result", value: outcome },
  { label: "receipt", value: "evt_4f2a...sealed", emphasized: true },
];
---

<section
  class="learn-example-band relative left-1/2 isolate w-dvw max-w-dvw -translate-x-1/2 overflow-hidden border-y border-ink-100/12 px-6 lg:px-8"
>
  <div
    class="pointer-events-none absolute inset-0 bg-[linear-gradient(rgba(116,83,49,0.075)_1px,transparent_1px),linear-gradient(90deg,rgba(116,83,49,0.075)_1px,transparent_1px)] bg-size-[6rem_6rem] opacity-45"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_72%_36%,rgba(37,99,235,0.06),transparent_32%)]"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-0 hidden lg:block"
    aria-hidden="true"
  >
    <span
      class="learn-example-vertical absolute inset-y-0 left-[calc(50%-36rem+3.25rem)] w-px bg-ink-300/16"
    ></span>
    <span
      class:list={[
        "learn-example-vertical absolute inset-y-0 w-px bg-sand-100/70",
        mirrored ? "left-[47%]" : "left-[53%]",
      ]}
    >
    </span>
    <span
      class="learn-example-vertical absolute inset-y-0 right-[7rem] w-px bg-ink-300/16"
    ></span>
  </div>
  <span
    class="absolute top-0 left-1/2 h-px w-screen -translate-x-1/2 bg-ink-300/20"
    aria-hidden="true"></span>
  <span
    class="absolute bottom-0 left-1/2 h-px w-screen -translate-x-1/2 bg-ink-300/20"
    aria-hidden="true"></span>

  <div
    class:list={[
      "relative mx-auto grid max-w-6xl",
      mirrored ? "lg:grid-cols-[47%_53%]" : "lg:grid-cols-[53%_47%]",
    ]}
  >
    <span
      class="absolute top-8 -left-6 size-3 border-t border-l border-ink-100/25"
      aria-hidden="true"></span>
    <span
      class="absolute -right-6 bottom-8 size-3 border-r border-b border-ink-100/25"
      aria-hidden="true"></span>

    <div
      class:list={[
        "relative p-5 sm:p-8 lg:py-14 xl:py-16",
        mirrored
          ? "lg:order-2 lg:pr-0 lg:pl-12"
          : "lg:order-1 lg:pr-12 lg:pl-0",
      ]}
    >
      <div class="mb-8 max-w-2xl sm:mb-10">
        <p class="font-mono text-xs tracking-widest text-sand-600 uppercase">
          {eyebrow}
        </p>
        <h2
          class="mt-4 text-3xl font-semibold tracking-tight text-balance text-ink-100 sm:text-4xl xl:text-5xl"
        >
          {title}
        </h2>
        {
          description && (
            <p class="mt-5 max-w-xl text-base leading-7 text-balance text-ink-100/68 sm:text-lg">
              {description}
            </p>
          )
        }
      </div>

      <ol class="relative border-y border-ink-100/10">
        {
          timeline.map((step, index) => {
            const stepNumber = String(index + 1).padStart(2, "0");
            const nextColor = timeline[index + 1]?.color;
            return (
              <li
                class="learn-example-step relative grid grid-cols-[2.5rem_minmax(0,1fr)] gap-5 border-b border-ink-100/10 py-5 last:border-b-0 sm:py-6"
                style={`animation-delay: ${step.delay}ms`}
              >
                {nextColor && (
                  <span
                    class:list={[
                      "learn-example-line pointer-events-none absolute top-10 left-5 h-full w-px -translate-x-1/2 bg-linear-to-b sm:top-11",
                      `from-${step.color}-400`,
                      `to-${nextColor}-400`,
                    ]}
                    aria-hidden="true"
                  />
                )}
                <div class="relative flex justify-center">
                  <span
                    class:list={[
                      "relative z-10 grid size-10 place-items-center rounded-md border bg-ink-950 font-mono text-[0.68rem] shadow-[0_0_24px_rgba(96,165,250,0.14)]",
                      `border-${step.color}-400/50`,
                      `text-${step.color}-700`,
                    ]}
                  >
                    {stepNumber}
                  </span>
                </div>

                <div class="min-w-0 pt-0.5">
                  <p class="font-mono text-xs tracking-widest text-sand-600/65 uppercase">
                    {step.label}
                  </p>
                  <p class="mt-2 max-w-xl text-base leading-6 text-balance text-ink-200 sm:text-lg sm:leading-7">
                    {step.text}
                  </p>
                </div>
              </li>
            );
          })
        }
      </ol>
    </div>

    <div
      class:list={[
        "relative grid min-h-96 place-items-center p-8 sm:p-10 lg:py-14 xl:py-16",
        mirrored
          ? "lg:order-1 lg:pr-14 lg:pl-0"
          : "lg:order-2 lg:pr-0 lg:pl-14",
      ]}
    >
      <div class="learn-example-feature w-full max-w-md lg:max-w-lg">
        <div
          class="mb-10 h-px w-24 bg-linear-to-r from-sand-600/45 to-transparent"
        >
        </div>
        <div class="text-left">
          <p class="font-mono text-sm tracking-widest text-sand-600 uppercase">
            {featureLabel}
          </p>
          <p
            class="mt-7 max-w-[115%] overflow-visible font-mono text-[clamp(2.8rem,5.2vw,5rem)] leading-none tracking-[-0.08em] text-ink-200"
          >
            {feature}
          </p>
        </div>

        <div
          class="mt-8 rounded-2xl border border-ink-100/10 bg-ink-950/75 p-4 text-left shadow-[0_20px_70px_rgba(15,23,42,0.10)]"
        >
          <div
            class="flex items-center justify-between gap-3 border-b border-ink-100/10 pb-3"
          >
            <p
              class="font-mono text-[0.68rem] tracking-widest text-sand-600 uppercase"
            >
              {artifactTitle}
            </p>
            <span
              class="rounded-full border border-emerald-300/25 bg-emerald-300/10 px-2 py-1 font-mono text-[0.62rem] tracking-widest text-emerald-700 uppercase"
            >
              {artifactStatus}
            </span>
          </div>
          <dl class="mt-4 space-y-3 font-mono text-xs leading-5">
            {
              resolvedArtifactRows.map((row) => (
                <div class="grid grid-cols-[5.5rem_minmax(0,1fr)] gap-3">
                  <dt class="text-sand-600/65">{row.label}</dt>
                  <dd
                    class:list={[
                      "text-ink-200",
                      row.emphasized && "text-cyan-700",
                    ]}
                  >
                    {row.value}
                  </dd>
                </div>
              ))
            }
          </dl>
        </div>

        <a
          class="mt-8 inline-flex items-center rounded-full border border-ink-100/15 bg-ink-100 px-6 py-3 text-sm font-semibold text-ink-950 transition hover:-translate-y-px hover:bg-ink-100"
          href="/install"
        >
          {cta}
        </a>
      </div>
    </div>
  </div>
</section>
