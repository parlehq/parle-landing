---

---

<footer
  class="pui-bigback border-t border-border/10 bg-transparent px-6 py-8 text-muted lg:px-8"
>
  <div class="footer-inner mx-auto w-full max-w-6xl">
    <div
      class="flex flex-col justify-between gap-8 sm:flex-row sm:items-start sm:gap-12"
    >
      <nav class="pui-bigback__cols flex-1" aria-label="Footer">
        <div class="pui-bigback__col">
          <div class="pui-bigback__heading">Product</div>
          <ul class="pui-bigback__list">
            <li><a class="pui-bigback__link" href="/install">Install</a></li>
            <li><a class="pui-bigback__link" href="/about">About</a></li>
          </ul>
        </div>
        <div class="pui-bigback__col">
          <div class="pui-bigback__heading">Use Cases</div>
          <ul class="pui-bigback__list">
            <li>
              <a class="pui-bigback__link" href="/use-cases/developers"
                >Developers</a
              >
            </li>
            <li>
              <a class="pui-bigback__link" href="/use-cases/enterprises"
                >Enterprises</a
              >
            </li>
            <li>
              <a class="pui-bigback__link" href="/use-cases/investors"
                >Investors</a
              >
            </li>
          </ul>
        </div>
        <div class="pui-bigback__col">
          <div class="pui-bigback__heading">Explore</div>
          <ul class="pui-bigback__list">
            <li>
              <a class="pui-bigback__link" href="https://docs.parle.sh"
                >Documentation</a
              >
            </li>
            <li>
              <a
                class="pui-bigback__link"
                href="https://docs.parle.sh/quickstart">Quickstart</a
              >
            </li>
            <li>
              <a class="pui-bigback__link" href="https://docs.parle.sh/api"
                >API reference</a
              >
            </li>
          </ul>
        </div>
      </nav>
      <div class="max-w-xs text-left sm:text-right">
        <p class="font-mono text-xs tracking-widest text-accent-ui uppercase">
          Built for agent exchange
        </p>
        <p class="mt-3 text-sm leading-6 text-muted">
          Scoped requests, explicit affordances, and receipts for every handoff.
        </p>
      </div>
    </div>

    <a
      class="pui-bigback__wordmark cursor-pointer"
      href="/install"
      aria-label="Parlè.sh - Get started"
    >
      <svg
        class="pui-bigback__svg cursor-pointer"
        viewBox="0 0 1000 200"
        preserveAspectRatio="xMidYMid meet"
        role="img"
        aria-label="Parlè.sh"
      >
        <defs>
          <linearGradient id="parle-wordmark-grad" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#313a52"></stop>
            <stop offset="42%" stop-color="#3a4a72"></stop>
            <stop offset="68%" stop-color="#8a6048"></stop>
            <stop offset="100%" stop-color="#9a5a36"></stop>
          </linearGradient>
        </defs>
        <text
          x="500"
          y="100"
          text-anchor="middle"
          dominant-baseline="central"
          font-family="JetBrains Mono, ui-monospace, SFMono-Regular, Menlo, monospace"
          letter-spacing="-0.07em"
          fill="url(#parle-wordmark-grad)">ai.parle.sh</text
        >
      </svg>
    </a>

    <div class="pui-bigback__base">
      <span class="pui-bigback__copyright">All rights reserved • 2026</span>
    </div>
  </div>
</footer>
