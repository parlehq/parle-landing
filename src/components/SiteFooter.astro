---

---

<footer
  class="pui-bigback border-t border-white/10 bg-transparent px-6 py-8 text-ink-200 lg:px-8"
>
  <div class="footer-inner mx-auto w-full max-w-4xl">
    <div
      class="flex flex-col flex-wrap items-stretch justify-between gap-7 sm:flex-row sm:gap-[clamp(28px,5vw,56px)]"
    >
      <nav class="pui-bigback__cols flex-initial" aria-label="Footer">
        <div class="pui-bigback__col">
          <div class="pui-bigback__heading">Product</div>
          <ul class="pui-bigback__list">
            <li><a class="pui-bigback__link" href="/install">Install</a></li>
            <li><a class="pui-bigback__link" href="/about">About</a></li>
          </ul>
        </div>
        <div class="pui-bigback__col">
          <div class="pui-bigback__heading">Explore</div>
          <ul class="pui-bigback__list">
            <li><a class="pui-bigback__link" href="/v1">v1</a></li>
            <li><a class="pui-bigback__link" href="/ghostty">Ghostty</a></li>
          </ul>
        </div>
      </nav>

      <a
        class="m-auto inline-flex items-center justify-center self-center rounded-[10px] border border-ink-100/60 bg-ink-100/92 px-[2.1rem] py-[0.9rem] font-sans text-[1.05rem] font-semibold tracking-[0.01em] whitespace-nowrap text-ink-950 no-underline transition-[background,border-color,transform] duration-180 hover:-translate-y-px hover:border-white hover:bg-white max-sm:m-0 max-sm:self-stretch"
        href="/install">Get Started</a
      >
    </div>

    <a
      class="pui-bigback__wordmark cursor-pointer"
      href="/install"
      aria-label="Parlè.sh - Get started"
    >
      <svg
        class="pui-bigback__svg"
        viewBox="0 0 1000 200"
        preserveAspectRatio="xMidYMid meet"
        role="img"
        aria-label="Parlè.sh"
      >
        <defs>
          <linearGradient id="parle-wordmark-grad" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#ffffff"></stop>
            <stop offset="55%" stop-color="var(--color-ink-300)"></stop>
            <stop offset="100%" stop-color="var(--color-ink-500)"></stop>
          </linearGradient>
        </defs>
        <text
          x="500"
          y="100"
          text-anchor="middle"
          dominant-baseline="central"
          textLength="1000"
          lengthAdjust="spacingAndGlyphs"
          fill="url(#parle-wordmark-grad)">Parlè.sh</text
        >
      </svg>
    </a>

    <div class="pui-bigback__base">
      <span class="pui-bigback__copyright">All rights reserved • 2026</span>
    </div>
  </div>
</footer>
