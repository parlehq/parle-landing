---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const SITE = "https://parle.sh";
const {
  title = "Parlè",
  description = "Bounded communication across trust boundaries.",
} = Astro.props;
const path = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
const canonicalURL = `${SITE}${path}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/parle-icon-v4.png" />
    <link rel="apple-touch-icon" href="/parle-icon-v4.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Parlè" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&family=Momo+Trust+Display&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="overflow-x-clip font-sans antialiased">
    <slot />
  </body>
</html>
