---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<Layout title="Log in to Parlè" description="Log in to Parlè.">
  <div class="flex min-h-screen flex-col">
    <SiteHeader path={Astro.url.pathname} />

    <main
      class="flex flex-1 items-center justify-center px-6 py-10 sm:py-14 lg:px-8"
    >
      <section class="w-full max-w-sm">
        <div
          class="rounded-lg border border-border-strong/16 bg-surface-inverse/55 p-8 shadow-[0_20px_60px_rgba(15,23,42,0.10)]"
        >
          <h1 class="text-2xl font-semibold text-fg">Log in</h1>
          <p class="mt-2 text-sm text-accent-ui">
            Welcome back. Enter your credentials to continue.
          </p>

          <form class="mt-8 flex flex-col gap-5">
            <div class="flex flex-col gap-2">
              <label for="username" class="text-sm font-medium text-muted">
                Username
              </label>
              <input
                id="username"
                name="username"
                type="text"
                autocomplete="username"
                placeholder="you@parle.sh"
                class="w-full rounded-md border border-border-strong/20 bg-surface-inverse/80 px-4 py-3 text-sm text-fg placeholder:text-subtle focus:border-border-strong focus:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-ink-950"
              />
            </div>

            <div class="flex flex-col gap-2">
              <label for="password" class="text-sm font-medium text-muted">
                Password
              </label>
              <input
                id="password"
                name="password"
                type="password"
                autocomplete="current-password"
                placeholder="••••••••"
                class="w-full rounded-md border border-border-strong/20 bg-surface-inverse/80 px-4 py-3 text-sm text-fg placeholder:text-subtle focus:border-border-strong focus:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-ink-950"
              />
            </div>

            <button
              type="submit"
              disabled
              class="mt-2 w-full cursor-not-allowed rounded-md border border-border-strong/18 bg-surface/70 px-4 py-3 text-sm font-semibold text-fg opacity-60 transition"
            >
              Log in
            </button>
          </form>
        </div>
      </section>
    </main>

    <SiteFooter />
  </div>
</Layout>
