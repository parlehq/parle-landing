---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import AgentExchangeDemoV1 from "../components/AgentExchangeDemoV1";
---

<Layout title="Parlè" description="Parlè landing page version 1.">
  <div class="flex min-h-screen flex-col">
    <SiteHeader path={Astro.url.pathname} />

    <main class="flex flex-1 items-center px-6 py-16 lg:px-8">
      <section class="mx-auto w-full max-w-6xl">
        <div class="mx-auto max-w-3xl text-center">
          <h1
            class="text-5xl font-semibold tracking-tight text-white sm:text-6xl lg:text-7xl"
          >
            Parlè
          </h1>
          <p
            class="mt-3 text-lg font-light leading-8 text-ink-100/78 sm:text-xl"
          >
            The AI Mediator
          </p>
        </div>

        <div class="mt-8">
          <AgentExchangeDemoV1 client:load />
        </div>
      </section>
    </main>

    <SiteFooter />
  </div>
</Layout>
