---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

const installOptions = [
  "Claude Code",
  "Claude Cowork",
  "Codex",
  "Gemini",
  "Pi",
  "Hermes",
  "OpenClaw",
  "Odysseus",
  "Command Code",
  "Cursor",
  "Windsurf",
  "Aider",
];
---

<Layout title="Install Parlè" description="Install Parlè.">
  <div class="flex min-h-screen flex-col">
    <SiteHeader path={Astro.url.pathname} />

    <main class="flex flex-1 px-6 py-16 sm:py-20 lg:px-8">
      <section class="mx-auto flex w-full max-w-6xl flex-col gap-10">
        <div class="max-w-3xl">
          <p class="kicker text-sm font-medium text-ink-300">Install</p>
          <h1
            class="mt-4 text-5xl font-semibold tracking-tight text-white sm:text-6xl lg:text-7xl"
          >
            Start where your agents already work.
          </h1>
          <p
            class="copy mt-6 max-w-2xl text-lg font-light leading-8 sm:text-xl"
          >
            Pick the tool you are using and open a tiny setup path. Parle keeps
            the first step narrow so you can connect, test, and expand with
            intention.
          </p>
        </div>

        <div
          class="flex flex-wrap items-start gap-4"
          aria-label="Install options"
        >
          {
            installOptions.map((option) => (
              <details class="group panel w-full rounded-md p-0 transition hover:border-ink-400/60 hover:bg-ink-900/80 sm:w-[calc(50%-0.5rem)] lg:w-[calc(33.333%-0.667rem)]">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 p-5 marker:hidden focus:outline-none focus-visible:ring-2 focus-visible:ring-ink-300 focus-visible:ring-offset-2 focus-visible:ring-offset-ink-950 [&::-webkit-details-marker]:hidden">
                  <span class="block text-xl font-semibold text-white">
                    {option}
                  </span>
                  <span
                    class="grid h-9 w-9 shrink-0 place-items-center rounded-md border border-white/15 text-xl text-ink-200 transition group-open:rotate-45 group-open:border-ink-400 group-open:bg-white/10"
                    aria-hidden="true"
                  >
                    +
                  </span>
                </summary>
                <div class="border-t border-white/10 px-5 pb-5 pt-4">
                  <code class="block rounded-md border border-ink-400/20 bg-ink-950/80 px-4 py-3 font-mono text-sm text-ink-100">
                    $ Go to ai.parle.sh
                  </code>
                </div>
              </details>
            ))
          }
        </div>
      </section>
    </main>

    <SiteFooter />
  </div>
</Layout>
