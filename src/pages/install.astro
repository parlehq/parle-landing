---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

const installOptions = [
  {
    name: "Claude Code",
    note: "Bring Parle into a terminal-first coding loop.",
    tag: "CLI",
  },
  {
    name: "Claude Cowork",
    note: "Set up a shared handoff space for agent collaboration.",
    tag: "Workspace",
  },
  {
    name: "Codex",
    note: "Keep code agent context compact and observable.",
    tag: "Coding",
  },
  {
    name: "Gemini",
    note: "Connect a fast research and build companion.",
    tag: "AI",
  },
  {
    name: "Pi",
    note: "Wire Parle into the CentOps agent harness.",
    tag: "Harness",
  },
  {
    name: "Hermes",
    note: "Use a simple lane for agent messages and reviews.",
    tag: "Messaging",
  },
  {
    name: "OpenClaw",
    note: "Start with a bounded open agent workflow.",
    tag: "Open",
  },
  {
    name: "Odysseus",
    note: "Prepare longer-running work without widening trust too early.",
    tag: "Ops",
  },
  {
    name: "Command Code",
    note: "Add a lightweight setup path for command-driven coding.",
    tag: "Terminal",
  },
  {
    name: "Cursor",
    note: "Pair Parle with a popular AI editor workflow.",
    tag: "Editor",
  },
  {
    name: "Windsurf",
    note: "Give an agentic IDE a clear place to start.",
    tag: "Editor",
  },
  {
    name: "Aider",
    note: "Keep local repo changes small, direct, and reviewable.",
    tag: "Git",
  },
];
---

<Layout title="Install Parlè" description="Install Parlè.">
  <div class="flex min-h-screen flex-col">
    <SiteHeader path={Astro.url.pathname} />

    <main class="flex flex-1 px-6 py-16 sm:py-20 lg:px-8">
      <section class="mx-auto flex w-full max-w-6xl flex-col gap-10">
        <div class="max-w-3xl">
          <p class="kicker text-sm font-medium text-ink-300">Install</p>
          <h1
            class="mt-4 text-5xl font-semibold tracking-tight text-white sm:text-6xl lg:text-7xl"
          >
            Start where your agents already work.
          </h1>
          <p
            class="copy mt-6 max-w-2xl text-lg font-light leading-8 sm:text-xl"
          >
            Pick the tool you are using and open a tiny setup path. Parle keeps
            the first step narrow so you can connect, test, and expand with
            intention.
          </p>
        </div>

        <div
          class="flex flex-wrap items-start gap-4"
          aria-label="Install options"
        >
          {
            installOptions.map((option) => (
              <details class="group panel w-full rounded-3xl p-0 transition hover:border-ink-400/60 hover:bg-ink-900/80 sm:w-[calc(50%-0.5rem)] lg:w-[calc(33.333%-0.667rem)]">
                <summary class="flex cursor-pointer list-none items-start justify-between gap-4 p-5 marker:hidden focus:outline-none focus-visible:ring-2 focus-visible:ring-ink-300 focus-visible:ring-offset-2 focus-visible:ring-offset-ink-950 [&::-webkit-details-marker]:hidden">
                  <span>
                    <span class="inline-flex rounded-full border border-ink-400/20 bg-ink-500/10 px-2.5 py-1 text-xs font-medium text-ink-200">
                      {option.tag}
                    </span>
                    <span class="mt-4 block text-xl font-semibold text-white">
                      {option.name}
                    </span>
                    <span class="copy mt-2 block text-sm leading-6">
                      {option.note}
                    </span>
                  </span>
                  <span
                    class="mt-1 grid h-9 w-9 shrink-0 place-items-center rounded-full border border-white/15 text-xl text-ink-200 transition group-open:rotate-45 group-open:border-ink-400 group-open:bg-white/10"
                    aria-hidden="true"
                  >
                    +
                  </span>
                </summary>
                <div class="border-t border-white/10 px-5 pb-5 pt-4">
                  <p class="copy text-sm leading-6">
                    The setup stays the same for this first pass:
                  </p>
                  <code class="mt-3 block rounded-2xl border border-ink-400/20 bg-ink-950/80 px-4 py-3 font-mono text-sm text-ink-100">
                    $ Go to ai.parle.sh
                  </code>
                </div>
              </details>
            ))
          }
        </div>
      </section>
    </main>

    <SiteFooter />
  </div>
</Layout>
