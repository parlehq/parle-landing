---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

const installOptions = [
  "Claude Code",
  "Claude Cowork",
  "Codex",
  "Gemini",
  "Pi",
  "Hermes",
  "OpenClaw",
  "Odysseus",
  "Command Code",
  "Cursor",
  "Windsurf",
  "Aider",
];
---

<Layout title="Install Parlè" description="Install Parlè.">
  <div class="flex min-h-screen flex-col">
    <SiteHeader path={Astro.url.pathname} />

    <main class="flex flex-1 px-6 py-10 sm:py-14 lg:px-8">
      <section class="mx-auto flex w-full max-w-6xl flex-col gap-12">
        <div class="relative left-1/2 isolate w-dvw max-w-dvw -translate-x-1/2 overflow-hidden border-y border-white/12 bg-white/4 px-6 py-8 text-center shadow-[inset_0_1px_0_rgba(255,255,255,0.08),inset_0_-1px_0_rgba(255,255,255,0.04),0_24px_80px_rgba(2,6,23,0.26)] backdrop-blur-md sm:px-10 sm:py-12">
          <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_center,rgba(96,165,250,0.2),transparent_54%)]">
          </div>
          <div class="absolute inset-0 -z-10 bg-linear-to-b from-white/8 via-white/2 to-transparent">
          </div>

          <h1 class="mx-auto max-w-4xl text-balance text-white">
            <span
              class="block text-sm font-medium tracking-widest text-ink-300 uppercase"
            >
              Ask your agent of choice to go to
            </span>
            <a
              href="https://ai.parle.sh"
              class="parle-hover-wordmark mt-4 block font-mono text-[clamp(3.4rem,10vw,8rem)] leading-none tracking-[-0.07em]"
            >
              <span
                class="bg-linear-to-br from-white via-ink-200 to-ink-500 bg-clip-text text-transparent"
              >
                ai.parle.sh
              </span>
              <span class="parle-hover-wordmark__glow" aria-hidden="true">
                ai.parle.sh
              </span>
            </a>
            <span
              class="mt-5 block text-sm font-medium tracking-widest text-ink-300 uppercase"
            >
              We'll take it from there.
            </span>
          </h1>
        </div>

        <div
          class="flex flex-wrap items-start gap-4"
          aria-label="Install options"
        >
          {
            installOptions.map((option) => (
              <details class="group w-full rounded-md border border-ink-400/16 bg-ink-900/55 p-0 text-left shadow-[0_20px_60px_rgba(2,6,23,0.35)] transition hover:border-ink-400/60 hover:bg-ink-900/80 sm:w-[calc(50%-0.5rem)] lg:w-[calc(33.333%-0.667rem)]">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 p-5 marker:hidden focus:outline-none focus-visible:ring-2 focus-visible:ring-ink-300 focus-visible:ring-offset-2 focus-visible:ring-offset-ink-950 [&::-webkit-details-marker]:hidden">
                  <span class="block text-xl font-semibold text-white">
                    {option}
                  </span>
                  <span
                    class="grid h-9 w-9 shrink-0 place-items-center rounded-md border border-white/15 text-xl text-ink-200 transition group-open:rotate-45 group-open:border-ink-400 group-open:bg-white/10"
                    aria-hidden="true"
                  >
                    +
                  </span>
                </summary>
                <div class="border-t border-white/10 px-5 pb-5 pt-4">
                  <code class="block rounded-md border border-ink-400/20 bg-ink-950/80 px-4 py-3 font-mono text-sm text-ink-100">
                    $ Go to ai.parle.sh
                  </code>
                </div>
              </details>
            ))
          }
        </div>
      </section>
    </main>

    <SiteFooter />
  </div>
  <script>
    for (const wordmark of document.querySelectorAll<HTMLElement>(
      ".parle-hover-wordmark",
    )) {
      wordmark.addEventListener("pointermove", (event) => {
        const pointer = event as PointerEvent;
        const rect = wordmark.getBoundingClientRect();
        wordmark.style.setProperty(
          "--parle-hover-x",
          `${pointer.clientX - rect.left}px`,
        );
        wordmark.style.setProperty(
          "--parle-hover-y",
          `${pointer.clientY - rect.top}px`,
        );
      });
    }
  </script>
</Layout>
