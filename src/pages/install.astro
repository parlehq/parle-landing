---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

const installOptions = [
  "Claude Code",
  "Claude Cowork",
  "Codex",
  "Gemini",
  "Pi",
  "Hermes",
  "OpenClaw",
  "Odysseus",
  "Command Code",
  "Cursor",
  "Windsurf",
  "Aider",
];
---

<Layout title="Install Parlè" description="Install Parlè.">
  <div class="flex min-h-screen flex-col">
    <SiteHeader path={Astro.url.pathname} />

    <main class="flex flex-1 px-6 py-10 sm:py-14 lg:px-8">
      <section class="mx-auto flex w-full max-w-6xl flex-col gap-12">
        <div
          class="relative left-1/2 isolate w-dvw max-w-dvw -translate-x-1/2 overflow-hidden border-y border-border-strong/22 bg-surface/82 px-6 py-8 text-center shadow-[inset_0_1px_0_rgba(255,255,255,0.50),inset_0_-1px_0_rgba(154,90,54,0.16),0_24px_80px_rgba(24,32,51,0.09)] backdrop-blur-md sm:px-10 sm:py-12"
        >
          <div
            class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_center,rgba(74,90,138,0.09),transparent_58%)]"
          >
          </div>
          <div
            class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_64%_42%,var(--theme-accent-subtle),transparent_35%),linear-gradient(135deg,var(--theme-surface-strong),var(--theme-surface)_48%,var(--theme-accent-subtle))]"
          >
          </div>
          <div
            class="absolute inset-0 -z-10 bg-linear-to-b from-surface-strong/18 via-surface-strong/4 to-accent-ui/8"
          >
          </div>

          <h1 class="mx-auto max-w-4xl text-balance text-fg">
            <span
              class="block text-sm font-medium tracking-widest text-accent-ui uppercase"
            >
              Ask your agent of choice to go to
            </span>
            <a
              href="https://ai.parle.sh"
              class="parle-hover-wordmark mt-4 block pb-[0.08em] font-mono text-[clamp(3.4rem,10vw,8rem)] tracking-[-0.075em]"
            >
              <span class="parle-hover-wordmark__base">ai.parle.sh</span>
              <span class="parle-hover-wordmark__glow" aria-hidden="true">
                ai.parle.sh
              </span>
            </a>
            <span
              class="mt-5 block text-sm font-medium tracking-widest text-accent-ui uppercase"
            >
              We'll take it from there.
            </span>
          </h1>
        </div>

        <div
          class="flex flex-wrap items-start gap-4"
          aria-label="Install options"
        >
          {
            installOptions.map((option) => (
              <details class="group w-full rounded-md border border-border-strong/16 bg-surface-inverse/55 p-0 text-left shadow-[0_20px_60px_rgba(15,23,42,0.10)] transition hover:border-accent-ui/60 hover:bg-button-hover/80 sm:w-[calc(50%-0.5rem)] lg:w-[calc(33.333%-0.667rem)]">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 p-5 marker:hidden focus:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-ink-950 [&::-webkit-details-marker]:hidden">
                  <span class="block text-xl font-semibold text-fg">
                    {option}
                  </span>
                  <span
                    class="grid h-9 w-9 shrink-0 place-items-center rounded-md border border-border/15 text-xl text-muted transition group-open:rotate-45 group-open:border-accent-ui group-open:bg-button-hover/70"
                    aria-hidden="true"
                  >
                    +
                  </span>
                </summary>
                <div class="border-t border-border/10 px-5 pb-5 pt-4">
                  <code class="block rounded-md border border-border-strong/20 bg-surface-inverse/80 px-4 py-3 font-mono text-sm text-fg">
                    $ Go to ai.parle.sh
                  </code>
                </div>
              </details>
            ))
          }
        </div>
      </section>
    </main>

    <SiteFooter />
  </div>
  <script>
    for (const wordmark of document.querySelectorAll<HTMLElement>(
      ".parle-hover-wordmark",
    )) {
      wordmark.addEventListener("pointermove", (event) => {
        const pointer = event as PointerEvent;
        const rect = wordmark.getBoundingClientRect();
        wordmark.style.setProperty(
          "--parle-hover-x",
          `${pointer.clientX - rect.left}px`,
        );
        wordmark.style.setProperty(
          "--parle-hover-y",
          `${pointer.clientY - rect.top}px`,
        );
      });
    }
  </script>
</Layout>
