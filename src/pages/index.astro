---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

const principles = [
  {
    title: "Strictly bounded",
    body: "Parle starts narrow. Bilateral threads, explicit participants, append-only history, and no attempt to become a universal transport layer.",
  },
  {
    title: "Trust-aware by design",
    body: "It is built for communication across trust boundaries where provenance, policy, and operator clarity matter more than chat volume.",
  },
  {
    title: "Portable where it counts",
    body: "The model stays transport-neutral so the same exchange contract can travel across systems without taking on the full weight of another protocol stack.",
  },
];
---

<Layout
  title="Parle - Bounded communication across trust boundaries"
  description="Parle is a transport-neutral, server-mediated exchange service for bounded communication across trust boundaries."
>
  <SiteHeader path={Astro.url.pathname} />

  <main>
    <section
      class="mx-auto max-w-6xl px-6 pb-20 pt-20 lg:px-8 lg:pb-28 lg:pt-28"
    >
      <div
        class="grid gap-16 lg:grid-cols-[minmax(0,1.2fr)_minmax(22rem,0.8fr)] lg:items-end"
      >
        <div>
          <p class="kicker text-xs font-semibold text-ink-400">Parle</p>
          <h1
            class="mt-6 max-w-4xl text-5xl font-semibold tracking-tight text-white sm:text-6xl lg:text-7xl"
          >
            Bounded communication across trust boundaries.
          </h1>
          <p class="copy mt-6 max-w-2xl text-lg leading-8 sm:text-xl">
            Parle is a transport-neutral, server-mediated exchange service built
            for deliberate, auditable communication between known participants.
          </p>
          <div class="mt-10 flex flex-col gap-4 sm:flex-row">
            <a
              href="https://parle.sh"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-ink-950 transition hover:scale-[1.01]"
            >
              Visit Parle.sh
            </a>
            <a
              href="/about"
              class="inline-flex items-center justify-center rounded-full border border-white/15 px-6 py-3 text-sm font-semibold text-white transition hover:border-ink-400 hover:bg-white/5"
            >
              About Parle
            </a>
          </div>
        </div>

        <div class="panel rounded-[2rem] p-8">
          <p class="kicker text-xs font-semibold text-ink-400">Current shape</p>
          <ul class="mt-6 space-y-4 text-sm leading-7 text-ink-200">
            <li>Strict bilateral threads</li>
            <li>Participant-bound node credentials</li>
            <li>Append-only canonical history</li>
            <li>Participant-facing projections</li>
            <li>Projection expiry with operator-retained history</li>
            <li>No Matrix requirement in the core model</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 pb-20 lg:px-8 lg:pb-28">
      <div class="grid gap-6 lg:grid-cols-3">
        {
          principles.map((item) => (
            <article class="panel rounded-3xl p-8">
              <h2 class="text-2xl font-semibold text-white">{item.title}</h2>
              <p class="copy mt-4 text-base leading-7">{item.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 pb-24 lg:px-8 lg:pb-32">
      <div class="panel rounded-[2rem] p-8 sm:p-10 lg:p-12">
        <p class="kicker text-xs font-semibold text-ink-400">Why it exists</p>
        <div
          class="mt-6 grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.9fr)]"
        >
          <div>
            <h2 class="text-3xl font-semibold text-white sm:text-4xl">
              A narrower layer for high-trust exchange.
            </h2>
            <p class="copy mt-5 max-w-2xl text-lg leading-8">
              Parle is not trying to be a new universal chat network. It is
              meant to prove that a smaller exchange layer can make sensitive,
              bounded communication cleaner and more durable.
            </p>
          </div>
          <div class="space-y-5 text-sm leading-7 text-ink-200">
            <p>
              The first build focuses on known participants, explicit scope, and
              history that remains intelligible under review.
            </p>
            <p>
              That makes it a good fit for workflows where context transfer
              matters, but sprawling, many-party coordination does not.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</Layout>
