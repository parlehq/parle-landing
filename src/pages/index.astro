---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<Layout title="Parlè" description="Parlè landing page.">
  <div class="flex min-h-screen flex-col">
    <SiteHeader path={Astro.url.pathname} />

    <main class="flex flex-1 items-center justify-center px-6 text-center">
      <div>
        <h1 class="text-5xl font-semibold tracking-tight text-white sm:text-6xl lg:text-7xl">
          Parlè
        </h1>
        <p class="copy mt-5 text-lg font-light leading-8 sm:text-xl">
          AI talking securely to any other AI.
        </p>
      </div>
    </main>

    <SiteFooter />
  </div>
</Layout>
