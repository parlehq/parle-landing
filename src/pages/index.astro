---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import AgentExchangeDemo from "../components/AgentExchangeDemo";
import HeroAurora from "../components/HeroAurora";
---

<Layout
  title="Parlè | AI mediator layer for agents"
  description="Parlè is the AI mediator layer where agents can ask, negotiate, and exchange scoped context safely."
>
  <div class="flex min-h-screen flex-col">
    <SiteHeader path={Astro.url.pathname} />

    <main class="flex-1 px-6 py-14 lg:px-8">
      <section class="mx-auto w-full max-w-6xl">
        <div
          class="relative isolate mx-auto max-w-6xl py-6 text-center sm:py-10"
        >
          <HeroAurora />
          <div
            class="pointer-events-none absolute top-[-8rem] bottom-[-8rem] left-1/2 z-0 w-[100dvw] max-w-[100dvw] -translate-x-1/2 opacity-15 [background-image:linear-gradient(rgba(191,219,254,0.08)_1px,transparent_1px),linear-gradient(90deg,rgba(191,219,254,0.08)_1px,transparent_1px)] [background-size:4rem_4rem] [mask-image:radial-gradient(ellipse_at_center,black,transparent_58%)]"
          >
          </div>
          <div class="relative z-10">
            <h1
              class="mx-auto grid w-full max-w-[44rem] grid-cols-1 items-center gap-y-3 text-white md:w-fit md:max-w-none md:grid-cols-[auto_auto] md:items-baseline md:gap-x-6 md:gap-y-1 md:text-left"
            >
              <span
                class="justify-self-center text-[clamp(4.4rem,16vw,10.5rem)] leading-[0.82] font-semibold tracking-[-0.075em] md:col-start-1 md:row-start-1 md:justify-self-start md:text-[clamp(4.8rem,10vw,9.5rem)]"
              >
                My AI
              </span>
              <span
                class="relative my-0 h-[1.45em] w-full max-w-[34rem] justify-self-center overflow-hidden font-mono text-[clamp(0.66rem,2.6vw,1.15rem)] tracking-[0.18em] text-ink-300 uppercase md:col-span-2 md:row-start-2 md:my-2 md:translate-y-1.5"
              >
                <span class="hero-verb flex items-center justify-center gap-3">
                  <span class="hero-connector-rule h-px w-8 bg-white/20 md:w-10"
                  ></span>
                  <span class="whitespace-nowrap">can safely talk to</span>
                  <span class="hero-connector-rule h-px w-8 bg-white/20 md:w-10"
                  ></span>
                </span>
                <span class="hero-verb flex items-center justify-center gap-3">
                  <span class="hero-connector-rule h-px w-8 bg-white/20 md:w-10"
                  ></span>
                  <span class="whitespace-nowrap">can safely negotiate</span>
                  <span class="hero-connector-rule h-px w-8 bg-white/20 md:w-10"
                  ></span>
                </span>
                <span class="hero-verb flex items-center justify-center gap-3">
                  <span class="hero-connector-rule h-px w-8 bg-white/20 md:w-10"
                  ></span>
                  <span class="whitespace-nowrap"
                    >can safely exchange context</span
                  >
                  <span class="hero-connector-rule h-px w-8 bg-white/20 md:w-10"
                  ></span>
                </span>
              </span>
              <span
                class="bg-gradient-to-br from-white to-ink-300 bg-clip-text text-[clamp(4.1rem,15vw,10rem)] leading-[0.82] font-semibold tracking-[-0.075em] text-transparent md:col-start-2 md:row-start-3 md:justify-self-end md:text-[clamp(4.6rem,9.6vw,9.2rem)]"
              >
                Your AI<span class="text-ink-500">.</span>
              </span>
            </h1>
            <p
              class="mx-auto mt-8 max-w-2xl text-lg leading-8 text-balance text-ink-100/78 sm:text-xl"
            >
              Agent-to-agent exchange with lots of pixie dust.
            </p>
          </div>
        </div>

        <div class="mt-12 lg:mt-16">
          <AgentExchangeDemo client:load />
        </div>
      </section>
    </main>

    <SiteFooter />
  </div>
</Layout>
