---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import AgentExchangeDemo from "../components/AgentExchangeDemo";
import HeroAurora from "../components/HeroAurora";
import LearnByExample from "../components/LearnByExample.astro";

const heroVerbs = [
  "can safely talk to",
  "can safely negotiate with",
  "can safely exchange context with",
  "can safely coordinate with",
];

// The hero verbs cross-fade one at a time. Timing scales with the count:
// each verb holds for `verbStepSeconds`, and the keyframe gives each one an
// even slot of the loop so any number of verbs stays evenly spaced.
const verbStepSeconds = 3.5;
const verbCycleSeconds = heroVerbs.length * verbStepSeconds;
const verbSlotPct = 100 / heroVerbs.length;
const verbHoldPct = Number((verbSlotPct * 0.8).toFixed(2));
const verbFadePct = Number(verbSlotPct.toFixed(2));
const heroVerbKeyframes = `@keyframes hero-verb-cycle {
  0%, ${verbHoldPct}% { opacity: 1; transform: translateY(0); }
  ${verbFadePct}%, 100% { opacity: 0; transform: translateY(-0.55em); }
}`;

const exampleSections = [
  {
    eyebrow: "Enabled by Parlè",
    title: "Hand off research without opening a side channel.",
    description:
      "The useful part is the room in the middle: Parlè checks who can ask, gives the helper only the slice it needs, and keeps a receipt of the handoff.",
    prompt:
      "Ask @researcher to compare OSS license options while I scaffold the package.",
    outcome:
      "Your agent gets the license summary, not the researcher's whole workspace, with a receipt for the exchange.",
    featureLabel: "Concept 01",
    feature: "requests",
    cta: "See how requests work",
    artifactTitle: "Request result",
    artifactStatus: "received",
    artifactRows: [
      { label: "route", value: "through Parlè, not agent-to-agent" },
      { label: "read", value: "task-sized view, not the whole session" },
      { label: "write", value: "safe retry with one recorded submission" },
      { label: "receipt", value: "evt_4f2a...sealed", emphasized: true },
    ],
    steps: [
      {
        label: "Route",
        text: "Your agent asks through Parlè, creating a room-owned request instead of a private side chat.",
        color: "violet",
      },
      {
        label: "Work",
        text: "The researcher sees the task and approved context, not your whole session. That narrow view is the projection.",
        color: "cyan",
      },
      {
        label: "Deliver",
        text: "The answer is recorded in the room, so your agent can retry safely and cite the receipt later.",
        color: "violet",
      },
    ],
  },
  {
    eyebrow: "Enabled by Parlè",
    title: "Let a helper agent discover the safe next move.",
    description:
      "Instead of guessing from a stale prompt, the agent can ask the room what it is allowed to do right now. Those available actions are affordances.",
    prompt:
      "I added @deployer to this repo. Have it figure out the staging actions it can use.",
    outcome:
      "The deployer learns the allowed staging actions from the room surface, while production controls never appear.",
    featureLabel: "Concept 02",
    feature: "affordances",
    cta: "See how affordances work",
    artifactTitle: "Available actions",
    artifactStatus: "scoped",
    artifactRows: [
      { label: "source", value: "same registry as the live API" },
      { label: "format", value: "OpenAPI, llms.txt, room actions" },
      { label: "allowed", value: "Staging deploys, log reads" },
      { label: "hidden", value: "Production config" },
    ],
    steps: [
      {
        label: "Ask",
        text: "The deployer asks the room what actions are available before choosing a tool path.",
        color: "violet",
      },
      {
        label: "Scope",
        text: "Parlè returns the actions this agent can actually use, generated from the live API registry.",
        color: "fuchsia",
      },
      {
        label: "Act",
        text: "The agent acts from the room contract instead of guessing from stale docs or a brittle system prompt.",
        color: "cyan",
      },
    ],
  },
  {
    eyebrow: "Enabled by Parlè",
    title: "Trace an answer back to what happened.",
    description:
      "A direct agent call leaves you trusting a transcript. Parlè records the important steps as room facts, then lets each agent read only its own view of them.",
    prompt:
      "Staging broke after @fixer and @deployer both touched the release. Show me what changed.",
    outcome:
      "You see the submitted events, the narrow view each agent read, and the receipt behind the final answer.",
    featureLabel: "Concept 03",
    feature: "receipts",
    cta: "See how receipts work",
    artifactTitle: "Exchange trail",
    artifactStatus: "traced",
    artifactRows: [
      { label: "events", value: "message submitted, room completed" },
      { label: "reads", value: "each agent's narrow room view" },
      { label: "record", value: "append-only history" },
      { label: "receipt", value: "evt_91bd...sealed", emphasized: true },
    ],
    steps: [
      {
        label: "Question",
        text: "You ask Parlè to explain which recorded steps led to the final response.",
        color: "violet",
      },
      {
        label: "Trace",
        text: "Parlè follows the submitted events and the room view each participant was allowed to read.",
        color: "fuchsia",
      },
      {
        label: "Fix",
        text: "Your agent gets an evidence-backed path to the bad handoff instead of a loose chat summary.",
        color: "cyan",
      },
    ],
  },
];
---

<Layout
  title="Parlè | Agent-to-agent mediation service."
  description="Parlè is the agent-to-agent mediation layer where agents can ask, negotiate, and exchange scoped context safely."
>
  <div class="flex min-h-screen flex-col">
    <SiteHeader path={Astro.url.pathname} />

    <main class="flex-1 px-6 py-14 lg:px-8">
      <section class="mx-auto w-full max-w-6xl">
        <div
          class="relative isolate mx-auto max-w-6xl py-6 text-center sm:py-10"
        >
          <HeroAurora />
          <div
            class="pointer-events-none absolute -top-32 -bottom-32 left-1/2 z-0 w-dvw max-w-dvw -translate-x-1/2 opacity-8 bg-[linear-gradient(rgba(116,83,49,0.075)_1px,transparent_1px),linear-gradient(90deg,rgba(116,83,49,0.075)_1px,transparent_1px)] bg-size-[4rem_4rem] mask-[radial-gradient(ellipse_at_center,black,transparent_58%)]"
          >
          </div>
          <style is:inline set:html={heroVerbKeyframes}></style>
          <div class="relative z-10">
            <h1
              class="mx-auto grid w-full max-w-176 grid-cols-1 items-center gap-y-3 text-ink-100 md:w-fit md:max-w-none md:grid-cols-[auto_auto] md:items-baseline md:gap-x-6 md:gap-y-1 md:text-left"
            >
              <span
                class="justify-self-center text-[clamp(4.4rem,16vw,10.5rem)] leading-[0.82] font-semibold tracking-[-0.075em] md:col-start-1 md:row-start-1 md:justify-self-start md:text-[clamp(4.8rem,10vw,9.5rem)]"
              >
                My AI
              </span>
              <span
                class="relative my-0 pt-8 translate-y-1 pb-0 md:pt-0 h-[1.3em] w-full max-w-128 justify-self-center overflow-hidden font-mono text-[clamp(0.62rem,2.2vw,0.98rem)] tracking-widest text-sand-600 uppercase md:col-span-2 md:row-start-2 md:my-1 md:translate-y-1"
                style={`--hero-verb-cycle: ${verbCycleSeconds}s`}
              >
                {
                  heroVerbs.map((verb, i) => (
                    <span
                      class="hero-verb flex items-center justify-center gap-3"
                      style={`--hero-verb-delay: ${(i * verbStepSeconds).toFixed(2)}s`}
                    >
                      <span class="hero-connector-rule h-px w-8 bg-sand-600/42 md:w-10" />
                      <span class="whitespace-nowrap">{verb}</span>
                      <span class="hero-connector-rule h-px w-8 bg-sand-600/42 md:w-10" />
                    </span>
                  ))
                }
              </span>
              <span
                class="text-[clamp(4.1rem,15vw,10rem)] leading-[0.82] font-semibold tracking-[-0.075em] text-ink-100 md:col-start-2 md:row-start-3 md:justify-self-end md:text-[clamp(4.6rem,9.6vw,9.2rem)]"
              >
                Your AI<span class="text-sand-600">.</span>
              </span>
            </h1>
            <p
              class="mx-auto mt-8 max-w-2xl text-lg leading-8 text-balance text-ink-200 sm:text-xl"
            >
              Agent-to-agent exchange with a lot of available guarantees.
            </p>
          </div>
        </div>

        <div class="mt-12 lg:mt-16">
          <AgentExchangeDemo client:load />
        </div>

        <div class="mt-20 lg:mt-28">
          {
            exampleSections.map((section, index) => (
              <LearnByExample {...section} mirrored={index === 1} />
            ))
          }
        </div>
      </section>
    </main>

    <SiteFooter />
  </div>
</Layout>
