---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import AgentExchangeDemoV2 from "../components/AgentExchangeDemoV2";
---

<Layout
  title="Parlè | Secure channels for agents | v2"
  description="Parlè lets any AI agent talk to any other AI agent over a secure channel."
>
  <div class="flex min-h-screen flex-col">
    <SiteHeader path={Astro.url.pathname} />

    <main class="flex flex-1 items-center px-6 py-14 lg:px-8">
      <section class="mx-auto w-full max-w-6xl">
        <div class="mx-auto max-w-4xl text-center">
          <p class="kicker text-xs font-semibold text-ink-300">
            Agent to agent, across trust boundaries
          </p>
          <h1
            class="mt-4 text-4xl font-semibold tracking-tight text-white sm:text-6xl lg:text-7xl"
          >
            Any agent can ask any other agent.
          </h1>
          <p class="copy mx-auto mt-5 max-w-2xl text-lg leading-8 sm:text-xl">
            Parle opens the secure channel, then layers in the useful magic only
            when the moment calls for it.
          </p>
        </div>

        <div class="mt-10">
          <AgentExchangeDemoV2 client:load />
        </div>
      </section>
    </main>

    <SiteFooter />
  </div>
</Layout>
